    "2": {
      "name": "قهوة FLY",
      "description": "استمتع بـ Fly Coffee بخصم 50%. سواء في المقهى أو للوجبات السفرية، تذوّق عبق كل فنجان بأفضل الأسعار."
    },
    "3": {
      "name": "ساعة مكررة",
      "description": "ساعة ذات آلية مكررة من إبداع الساعاتي الإنجليزي الشهير Francis Perigal (نشط 1741–67). علبة ذهبية جزئية المينا؛ ميناء من المينا البيضاء بأرقام سوداء وعقارب فضية مرصعة بالماس؛ حركة مطلية بالذهب. قمة فن صناعة الساعات في القرن الثامن عشر."
    },
    "4": {
      "name": "قيثارة",
      "description": "غيتار يُكسى ظهره وجوانبه ورقبته ورأسه بشرائط شيفرون من قشر السلحفاة والأبنوس والعاج، مع تضفيرات ملفوفة ومعينات وحواف هندسية. مزج بارع للأخشاب والتطعيم يكشف عن مهارة صانعه الاستثنائية."
    },
    "5": {
      "name": "صندوق موسيقى",
      "description": "صندوق موسيقى سويسري يعود إلى نحو 1820، على هيئة الماندولين. صُنع من مواد متعددة بحرفية عالية، ويمزج بين فن صناديق الموسيقى الأوروبية في مطلع القرن التاسع عشر وبين الجمالية الخاصة بآلة الماندولين."
    },
    "6": {
      "name": "قيثارة",
      "description": "غيتار فاخر الزخرفة من إبداع Giacomo (Jacob) Ertel في نهاية القرن السابع عشر. خشب التنّوب والأبنوس وأخشاب الفاكهة والعظم والعاج والصَّدَف والرق. يجمع العمل بين شغف الحرفي الألماني بالزخرفة وتقاليد صناعة الغيتار الإيطالية."
    },
    "7": {
      "name": "صباح شتوي في الريف",
      "description": "طبعة حجرية ملوّنة يدويًا من ورشة Currier & Ives، 1873. مشهد ريفي مغطى بالثلوج: مزلجة يجرها حصانان تحمل زوجين وأربعة كُوبٍ كبيرة للحليب، وفي الخلفية مزرعة. نموذج أمريكي بارز لفن الحياة اليومية في القرن التاسع عشر."
    },
    "8": {
      "name": "أعطني الحرية أو أعطني الموت!",
      "description": "طبعة حجرية ملوّنة يدويًا من Currier & Ives عام 1876 بعنوان \"أعطني الحرية أو أعطني الموت!\". تصوّر Patrick Henry وهو يلقي خطابه الشهير حول حقوق المستعمرات أمام جمعية فرجينيا في ريتشموند، مارس 1775."
    },
    "9": {
      "name": "صندوق موسيقى",
      "description": "صندوق موسيقى سويسري مستطيل من الذهب والمينا، نحو 1820. الحواف مزينة بالمينا الزرقاء والصفراء؛ يحمل الغطاء منمنمة كلاسيكية مينائية محاطة بأنصاف لآلئ. تلاقٍ مثالي بين فن صناديق الموسيقى وفن صياغة الحلي."
    },
    "10": {
      "name": "علبة ساعة",
      "description": "علبة ساعة من صنع George Harrison نحو 1770. ذهب مزيّن جزئيًا بالمينا؛ وتحتوي العلبة الخارجية على ألماس بارز اللمعان، دلالة على مهارة عالية لصنّاع الساعات والمجوهرات البريطانيين في القرن الثامن عشر."
    },
    "11": {
      "name": "آلة الديفيجن فيول",
      "description": "فيول تقسيمي من صنع Richard Meares نحو 1680. من التنّوب والأبنوس والقيقب. كانت آلات الفيول أبرز الآلات الوترية المقوَّسة في أواخر عصر النهضة، ثم حلّت محلها الكمانات تدريجيًا في القرن السابع عشر. شاهد هام على تاريخ الموسيقى."
    },
    "12": {
      "name": "تنين",
      "description": "تنين برونزي يعود إلى مطلع القرن السابع عشر من إبداع Giacomo Laurenziani. صُنِّف عند شرائه بوصفه عنقاء، ثم أعاد James Parker تحديده تنينًا بدءًا من خمسينيات القرن العشرين؛ تحفة نحت باروكية."
    },
    "13": {
      "name": "ورود وزنابق",
      "description": "Henri Fantin-Latour، 1888، زيت على قماش. هذا العمل الذي يحتفظ بحالة ممتازة يُظهر براعة الرسام في التعامل مع الصبغات: لا يستعمل الفرشاة فحسب، بل طرف مقبضها أيضًا ليُشكّل الورود والزنابق بأضواء وملمس بالغي الرقة."
    },
    "14": {
      "name": "ساعة",
      "description": "ساعة من صنع F. L. Meybom نحو 1670–75. العلبة من الذهب والفولاذ الأزرق والبلور الصخري والفضة المطلية جزئيًا مع ألماس؛ ميناء بمينا مطلية وأسلوب basse-taille على الذهب؛ حركة من نحاس مطلي بالذهب وفولاذ أزرق جزئيًا."
    },
    "15": {
      "name": "بروش اليعسوب",
      "description": "بروش يعسوب بأسلوب آرت نوفو من إبداع Edgar Bense نحو 1890. ذهب وألماس ومينا. الأجنحة الدقيقة بأسلوب plique-à-jour تُتوّج يعسوبًا مشكلاً بدقة بالغة، ويجسد العمل أناقة الآرت نوفو والجمالية الطبيعية."
    },
    "16": {
      "name": "سوار ذراع",
      "description": "سوار هندي (bazuband) من القرن التاسع عشر. ذهب مجدول مرصع بالياقوت وألماسة وردية القَطْع. تُوجد أمثلة مماثلة في تقاليد صياغة الحلي الأرستقراطية الهندية التي ورثت الجمالية البلاطية المغولية."
    },
    "17": {
      "name": "مجموعة درع جورج كليفورد",
      "description": "طقم درع صنعه Jacob Halder في مستودع الأسلحة الملكي في غرينتش عام 1586 للسيد George Clifford. فولاذ وذهب وجلد ومنسوجات. عُيِّن Clifford (1558–1605) بطل الملكة عام 1590 ومُنح وسام الرَّباط في العام نفسه."
    },
    "18": {
      "name": "بروش على شكل رأس بومة",
      "description": "بروش على هيئة رأس بومة من إبداع Castellani نحو 1860. ذهب وعقيق. تعكس هذه القطعة والمجموعة التي تنتمي إليها (انظر 2014.713.1–.10) الشغف الأوروبي في القرن التاسع عشر بالأساليب التاريخية، وتجسّد مجوهرات الإحياء الأثري."
    },
    "19": {
      "name": "ساعة",
      "description": "ساعة من صنع Charles Bobinet نحو 1655–60. علبة من عقيق بمُركّبات ذهب مينائي؛ ميناء مينا بيضاء بعقرب ذهبي؛ حركة من نحاس مطلي وفولاذ أزرق جزئيًا. شاهدة على حرفة صناعة الساعات الأوروبية في منتصف القرن السابع عشر."
    },
    "20": {
      "name": "الزنابق",
      "description": "فنسنت فان جوخ، 1890، زيت على قماش. لوحة السوسن الشهيرة. من أبرز أعمال المرحلة الأخيرة للفنان؛ بألوانها الغنية ولمساتها الحيّة تُبدي تكريمه العميق لجمال الطبيعة."
    },
    "21": {
      "name": "وعاء سكر بغطاء",
      "description": "سكرية ذات غطاء من صنع Giovacchino Belli نحو 1811–22. فضة مطلية بالذهب. تبدو قراءة Belli للطراز الإمبراطوري أكثر استرخاءً وحميمية من تفسيرات الفرنسيين المعاصرين، إذ تخفف الخطوط الكلاسيكية الصارمة بطابع إيطالي مميّز."
    },
    "22": {
      "name": "إبريق",
      "description": "إبريق (ewer) من فضة مطلية ومينا نحو 1600. يُزين جسمه موكب من الأشخاص والحيوانات يمثل انتصار قيصر عند عودته من مصر أو انتصار سكيبيو الإفريقي بعد هزيمة حنّبعل؛ قطعة معدنية بارزة من أواخر عصر النهضة."
    },
    "23": {
      "name": "الممثل Asao Gakujūrō I بدور Mashiba Hisatsugu",
      "description": "طبعة خشبية من إبداع Shunkōsai Hokushū (أوساكا) عام 1822. Nishiki-e على ورق بحبر وألوان، بتنسيق ōban الياباني العمودي. يصوّر الممثل الكابوكي الأوساكي Asao Gakujūrō I في دور Mashiba Hisatsugu بنظرة حادة ووضعية تحدٍ مفعمة بالدراما."
    },
    "24": {
      "name": "تاج جبال الأنديز",
      "description": "\"تاج الأنديز\" — الإكليل نحو 1660 والأقواس نحو 1770. كولومبي من Popayán. ذهب مطروق ومحفور مرصع بالزمرد. من أهم أعمال الصياغة في العصر الاستعماري لأمريكا الجنوبية، تجسيد إبداعي لدمج تقنيات أوروبية ومحلية."
    }
  },
