  "giftBox": {
    "1": {
      "name": "Müzik kutusu",
      "description": "Altın ve mineli kalkan biçimli kolye. Bir yüzünde su değirmenli otomaton çiftlik sahnesi, diğer yüzünde kırmızı zemin üzerinde bir gül. Her iki yüz de yarım incilerle özenle çerçevelenmiş; 18. yüzyıl dekoratif sanatının önemli bir örneği."
    },
    "2": {
      "name": "FLY Kahve",
      "description": "Fly Coffee'yi %50 indirimle yudumla. Mekânda ya da paket olarak, her fincanın kokusunu en iyi fiyatla yaşa."
    },
    "3": {
      "name": "Tekrar saati",
      "description": "İngiliz usta saatçı Francis Perigal (1741–67 döneminde aktif) tarafından yapılmış tekrarlamalı saat. Kısmen minelenmiş altın kasa; beyaz mine kadran üzerinde siyah rakamlar, elmas işlemeli gümüş ibreler; yaldızlı mekanizma. 18. yüzyıl saat sanatının zirvesi."
    },
    "4": {
      "name": "Gitar",
      "description": "Kaplumbağa kabuğu, abanoz ve fildişinden chevron desenler ile girift sarmallar, eşkenar dörtgenler ve geometrik şeritlerle arkası, yanları, sapı ve başı kaplı gitar. Ahşap ve kakma sanatının ustaca birleşimi, yapımcısının olağanüstü hünerini gösterir."
    },
    "5": {
      "name": "Müzik kutusu",
      "description": "Yaklaşık 1820 yılına ait, mandolin biçimli İsviçre müzik kutusu. Çeşitli malzemelerle titizlikle hazırlanmış; 19. yüzyıl başı Avrupa müzik kutusu sanatı ile mandolin enstrümanının estetik çizgisini birleştirir."
    },
    "6": {
      "name": "Gitar",
      "description": "Giacomo (Jacob) Ertel'in 17. yüzyıl sonunda yaptığı son derece süslü gitar. Ladin, abanoz, meyve ağaçları, kemik, fildişi, sedef ve parşömen kullanılmış. Eser, Alman ustanın süslemeye olan tutkusunu İtalyan gitar yapım geleneğiyle harmanlar."
    },
    "7": {
      "name": "Kırsalda Kış Sabahı",
      "description": "Currier & Ives stüdyosunun 1873 tarihli el boyaması taş baskısı. Karlı bir kırsal sahne: iki at tarafından çekilen kızakta bir çift ve dört büyük süt güğümü; uzakta çiftlik evi. 19. yüzyıl Amerikan halk ressamlığının tipik örneği."
    },
    "8": {
      "name": "Ya özgürlük ya ölüm!",
      "description": "Currier & Ives'in 1876 tarihli el boyaması taş baskısı \"Bana özgürlük verin ya da ölüm!\". Mart 1775'te Richmond'daki Virginia Meclisi önünde Patrick Henry'nin sömürgelerin hakları üzerine yaptığı ünlü konuşmayı canlandırır."
    },
    "9": {
      "name": "Müzik kutusu",
      "description": "Yaklaşık 1820 tarihli İsviçre yapımı uzun dörtgen altın-mineli müzik kutusu. Kenarları mavi ve sarı mine ile süslenmiş; kapakta yarım incilerle çevrilmiş klasik mine minyatür bulunuyor. Müzik kutusu sanatı ile mücevhercilik kusursuz bir biçimde birleşir."
    },
    "10": {
      "name": "Saat kasası",
      "description": "George Harrison tarafından yaklaşık 1770 yılında yapılan saat kasası. Kısmen minelenmiş altın; dış kasa pırıl pırıl elmaslarla kakılmıştır. 18. yüzyıl İngiliz saatçilik ve mücevhercilik ustalığının açık göstergesi."
    },
    "11": {
      "name": "Division Viol",
      "description": "Richard Meares'in yaklaşık 1680'de yaptığı bölme violi. Ladin, abanoz, akçaağaç. Geç Rönesans'ın en saygın yaylı çalgılarından olan violler, 17. yüzyıl boyunca yavaş yavaş yerini kemana bıraktı; müzik tarihinin önemli bir tanığıdır."
    },
    "12": {
      "name": "Ejderha",
      "description": "17. yüzyıl başında Giacomo Laurenziani'nin yaptığı bronz ejder. Koleksiyona alındığında grifon olarak kataloglanmıştı; 1950'lerden sonra James Parker tarafından doğru şekilde ejder olarak yeniden tanımlandı. Barok heykelciliğin dikkat çekici örneği."
    },
    "13": {
      "name": "Güller ve zambaklar",
      "description": "Henri Fantin-Latour, 1888, tuval üzerine yağlı boya. Mükemmel durumdaki bu çalışma, sanatçının pigmente olan virtüözce hâkimiyetini gösterir: yalnızca fırça değil, fırçanın sap ucunu da kullanarak gülleri ve zambakları enfes ışık ve dokuyla modellemiştir."
    },
    "14": {
      "name": "Saat",
      "description": "F. L. Meybom'un yaklaşık 1670–75 yıllarındaki cep saati. Kasa altın, mavilenmiş çelik, dağ kristali ve kısmen yaldızlı gümüş ile elmaslardan oluşur; kadran altın üzerine boyalı mine ve basse-taille mine; mekanizma yaldızlı pirinç ve kısmen mavilenmiş çelik."
    },
    "15": {
      "name": "Yusufçuk broş",
      "description": "Edgar Bense'in yaklaşık 1890 yılına ait Art Nouveau yusufçuk broşu. Altın, elmas ve mine. Zarif plique-à-jour minesiyle işlenmiş kanatlar, özenle şekillendirilmiş bir yusufçuğu süsler; Art Nouveau modasını ve natüralist estetiği bünyesinde somutlaştırır."
    },
    "16": {
      "name": "Kol bileziği",
      "description": "19. yüzyıla ait Hint kol bileziği (bazubend). Örgü altına yakutlar ve bir rose-cut elmas kakılmış. Benzer örnekler, Babür saray estetiğinin varisi olan Hint aristokrat mücevher geleneğinde görülür."
    },
    "17": {
      "name": "George Clifford'un zırh takımı",
      "description": "Kraliçe'nin Şampiyonu George Clifford için Jacob Halder'ın 1586'da Greenwich Kraliyet Silah Deposu'nda yaptığı zırh takımı. Çelik, altın, deri ve kumaş. Clifford (1558–1605) 1590'da Kraliçe'nin Şampiyonu ilan edildi ve aynı yıl Jartiyer Şövalyesi oldu."
    },
    "18": {
      "name": "Baykuş başı şeklinde broş",
      "description": "Castellani'nin yaklaşık 1860 tarihli baykuş başlı broşu. Altın ve akik. Bu parça ve ait olduğu grup (bkz. 2014.713.1–.10) 19. yüzyıl Avrupa'sının tarihsel üsluplara duyduğu güçlü ilgiyi yansıtır; arkeolojik canlanma mücevherciliğinin temsilcisidir."
    },
    "19": {
      "name": "Saat",
      "description": "Charles Bobinet'nin yaklaşık 1655–60 tarihli cep saati. Akik kasa üzerine mineli altın süslemeler; beyaz mine kadran üzerinde altın ibre; yaldızlı pirinç ve kısmen mavilenmiş çelik mekanizma. 17. yüzyıl ortası Avrupa saatçilik ustalığının kanıtı."
    },
    "20": {
      "name": "İrisler",
      "description": "Vincent van Gogh, 1890, tuval üzerine yağlı boya. Ünlü Süsenler. Sanatçının son döneminin en simgesel eserlerinden biri; zengin renkleri ve canlı fırça vuruşlarıyla doğanın güzelliğine derin bir saygı duruşudur."
    },
    "21": {
      "name": "Kapaklı şekerlik",
      "description": "Giovacchino Belli'nin yaklaşık 1811–22 tarihli kapaklı şekerliği. Yaldızlı gümüş. Belli'nin Empire yorumu, aynı dönemin Fransız yorumuna göre daha rahat ve samimi görünür; katı neoklasik çizgileri yumuşatarak karakteristik bir İtalyan lezzeti katar."
    },
    "22": {
      "name": "Sürahi",
      "description": "Yaklaşık 1600 tarihli yaldızlı gümüş ve mineli ibrik. Gövdesi, Sezar'ın Mısır dönüşü zaferini ya da Hannibal'i yenmesinin ardından Scipio Africanus'un zaferini betimleyen figür ve hayvan alaylarıyla süslenmiştir. Geç Rönesans metal sanatının görkemli bir örneğidir."
    },
    "23": {
      "name": "Mashiba Hisatsugu rolünde oyuncu Asao Gakujūrō I",
      "description": "Shunkōsai Hokushū (Osaka), 1822, ağaç baskı ukiyo-e (nishiki-e). Kağıt üzerine mürekkep ve renkle, Japon ōban dikey formatında. Osaka Kabuki'sinin aktörü Asao Gakujūrō I'in Mashiba Hisatsugu rolünde, sert bakışı ve meydan okuyan duruşuyla olağanüstü dramatik bir tasvir."
    },
    "24": {
      "name": "And Dağları Tacı",
      "description": "\"And Dağları'nın Tacı\" — diadem yaklaşık 1660, kemerler yaklaşık 1770. Kolombiya, Popayán. Kabartma ve oyma altın, zümrüt kakmalı. Güney Amerika sömürge döneminin en önemli kuyumculuk eserlerinden biri; Avrupa ve yerli tekniklerin yaratıcı sentezidir."
    }
  },
