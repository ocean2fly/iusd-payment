  "giftBox": {
    "1": {
      "name": "Spieldose",
      "description": "Schildförmiger Anhänger aus Gold und Email. Eine Seite zeigt eine Automaten-Bauernhofszene mit Wasserrad, die andere eine Rose auf rotem Grund. Beide Seiten sind mit Halbperlen umrandet, ein beeindruckendes Zeugnis der dekorativen Kunst des 18. Jahrhunderts."
    },
    "2": {
      "name": "FLY Kaffee",
      "description": "Genieße Fly Coffee mit 50% Rabatt. Ob im Café oder zum Mitnehmen – erlebe das Aroma jeder Tasse zum besten Preis."
    },
    "3": {
      "name": "Repetieruhr",
      "description": "Repetieruhr von Francis Perigal (britisch, tätig 1741–67). Gehäuse aus teils emailliertem Gold; weißes Emaille-Zifferblatt mit schwarzen Ziffern und mit Diamanten besetzten Silberzeigern; vergoldetes Werk. Gipfel der Uhrmacherkunst des 18. Jahrhunderts."
    },
    "4": {
      "name": "Gitarre",
      "description": "Gitarre, deren Boden, Zargen, Hals und Kopf mit Chevrons aus Schildpatt, Ebenholz und Elfenbein belegt sind – mit Rahmenvoluten, Rauten und geometrischen Friesen. Eine meisterhafte Verbindung von Hölzern und Intarsien, Zeugnis außergewöhnlichen Könnens."
    },
    "5": {
      "name": "Spieldose",
      "description": "Schweizer Spieldose um 1820 in Form einer Mandoline. Aus verschiedenen Materialien kunstvoll gefertigt, verbindet sie die europäische Spieldosen-Kunst des frühen 19. Jahrhunderts mit der Ästhetik des Mandolineninstruments."
    },
    "6": {
      "name": "Gitarre",
      "description": "Überreich verzierte Gitarre von Giacomo (Jacob) Ertel, spätes 17. Jahrhundert. Fichte, Ebenholz, Obsthölzer, Knochen, Elfenbein, Perlmutt und Pergament. Das Werk vereint die dekorative Leidenschaft des deutschen Meisters mit der italienischen Lauten-/Gitarrentradition."
    },
    "7": {
      "name": "Wintermorgen auf dem Land",
      "description": "Handkolorierte Lithografie der Werkstatt Currier & Ives, 1873. Verschneite ländliche Szene: Ein von zwei Pferden gezogener Schlitten trägt ein Paar und vier große Milchkannen; in der Ferne der Bauernhof. Typisches Genrebild des amerikanischen 19. Jahrhunderts."
    },
    "8": {
      "name": "Gebt mir Freiheit oder gebt mir den Tod!",
      "description": "Handkolorierte Lithografie Currier & Ives, 1876, „Gebt mir Freiheit oder gebt mir den Tod!\". Patrick Henry hält seine berühmte Rede über die Rechte der Kolonien vor der Versammlung von Virginia, Richmond, März 1775."
    },
    "9": {
      "name": "Spieldose",
      "description": "Schweizer längliche Spieldose aus Gold und Email, um 1820. Ränder in Blau und Gelb emailliert; der Deckel trägt eine klassische Emaille-Miniatur, die mit Halbperlen umrandet ist. Perfekte Verbindung von Spieldosenkunst und Juwelierkunst."
    },
    "10": {
      "name": "Uhrgehäuse",
      "description": "Uhrgehäuse von George Harrison, um 1770. Teils emailliertes Gold; das Außengehäuse ist mit funkelnden Diamanten besetzt. Zeugnis der hohen Handwerkskunst britischer Uhrmacher und Juweliere des 18. Jahrhunderts."
    },
    "11": {
      "name": "Divisionsviole",
      "description": "Division Viol von Richard Meares, um 1680. Fichte, Ebenholz, Ahorn. Violen, die angesehensten Streichinstrumente der Spätrenaissance, wurden im Laufe des 17. Jahrhunderts nach und nach von der Violine verdrängt; ein bedeutendes musikhistorisches Zeugnis."
    },
    "12": {
      "name": "Drache",
      "description": "Bronzener Drache vom Beginn des 17. Jahrhunderts, Werk von Giacomo Laurenziani. Beim Erwerb als Greif katalogisiert, später – seit den 1950er-Jahren – von James Parker korrekt als Drache identifiziert; ein eindrucksvolles Beispiel barocker Skulptur."
    },
    "13": {
      "name": "Rosen und Lilien",
      "description": "Henri Fantin-Latour, 1888, Öl auf Leinwand. Das hervorragend erhaltene Werk zeigt die virtuose Pigmentführung des Malers: Er benutzt nicht nur den Pinsel, sondern auch das Stielende, um Rosen und Lilien mit einer erlesenen Licht- und Texturwirkung zu modellieren."
    },
    "14": {
      "name": "Uhr",
      "description": "Uhr von F. L. Meybom, um 1670–75. Gehäuse aus Gold, bläuendem Stahl, Bergkristall und teilvergoldetem Silber mit Diamanten; Zifferblatt aus gemaltem Email und Basse-taille-Email auf Gold; Werk aus vergoldetem Messing und teilgebläutem Stahl."
    },
    "15": {
      "name": "Libellenbrosche",
      "description": "Jugendstil-Libellenbrosche von Edgar Bense, um 1890. Gold, Diamanten und Email. Die zarten Flügel in Plique-à-jour-Email krönen eine fein modellierte Libelle und verkörpern Mode und Juwelierkunst des Jugendstils sowie die naturalistische Ästhetik."
    },
    "16": {
      "name": "Armreif",
      "description": "Indisches Armband (Bazuband), 19. Jahrhundert. Aus geflochtenem Gold mit Rubinen und einem Rosendiamant besetzt. Ähnliche Beispiele finden sich in der Tradition der aristokratischen indischen Juwelierkunst, Erbin der Mogul-Hofästhetik."
    },
    "17": {
      "name": "Rüstgarnitur des George Clifford",
      "description": "Rüstungsgarnitur, die Jacob Halder 1586 in der Königlichen Rüstkammer Greenwich für George Clifford anfertigte. Stahl, Gold, Leder und Textil. Clifford (1558–1605) wurde 1590 zum Queen's Champion ernannt und im selben Jahr zum Ritter des Hosenbandordens."
    },
    "18": {
      "name": "Brosche in Form eines Eulenkopfs",
      "description": "Eulenkopfbrosche von Castellani, um 1860. Gold und Achat. Dieses Stück und die zugehörige Gruppe (siehe 2014.713.1–.10) spiegeln das intensive Interesse des 19. Jahrhunderts an historischen Stilen wider und verkörpern die Juwelierkunst des archäologischen Revivals."
    },
    "19": {
      "name": "Uhr",
      "description": "Uhr von Charles Bobinet, um 1655–60. Achatgehäuse mit Emaille-Goldmontierung; weißes Emaille-Zifferblatt mit Goldzeiger; Werk aus vergoldetem Messing und teilgebläutem Stahl. Beleg der europäischen Uhrmacherkunst Mitte des 17. Jahrhunderts."
    },
    "20": {
      "name": "Schwertlilien",
      "description": "Vincent van Gogh, 1890, Öl auf Leinwand. Die berühmten Schwertlilien. Eines der prägendsten Werke der Spätphase des Künstlers: mit üppigen Farben und lebendiger Pinselführung eine tiefe Huldigung an die Schönheit der Natur."
    },
    "21": {
      "name": "Zuckerdose mit Deckel",
      "description": "Zuckerdose mit Deckel von Giovacchino Belli, um 1811–22. Silber vergoldet. Bellis Lesart des Empirestils ist entspannter und einladender als die zeitgenössische französische Interpretation, mildert die strengen klassizistischen Linien und zeigt typisch italienischen Charakter."
    },
    "22": {
      "name": "Kanne",
      "description": "Kanne aus Silber-Vergoldung und Email, um 1600. Der Korpus ist mit einem Zug von Figuren und Tieren verziert, der entweder den Triumph Caesars nach seiner Rückkehr aus Ägypten oder den Triumph des Scipio Africanus nach dem Sieg über Hannibal darstellt."
    },
    "23": {
      "name": "Der Schauspieler Asao Gakujūrō I als Mashiba Hisatsugu",
      "description": "Holzschnitt von Shunkōsai Hokushū (Osaka), 1822. Nishiki-e auf Papier mit Tusche und Farbe, japanisches ōban-Hochformat. Zeigt den Kabuki-Schauspieler Asao Gakujūrō I. in der Rolle des Mashiba Hisatsugu mit wildem Blick und trotziger Pose voller Dramatik."
    },
    "24": {
      "name": "Krone der Anden",
      "description": "„Krone der Anden\" – Diadem um 1660, Bögen um 1770. Kolumbianisch, aus Popayán. Getriebenes und ziseliertes Gold mit Smaragden. Eines der wichtigsten Goldschmiedestücke des südamerikanischen Kolonialzeitalters, eine kreative Synthese europäischer und einheimischer Techniken."
    }
  },
