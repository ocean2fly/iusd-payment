  "giftBox": {
    "1": {
      "name": "Carillon",
      "description": "Pendente a scudo in oro e smalto. Una faccia rappresenta una scena di fattoria con automa e ruota ad acqua; l'altra una rosa su fondo rosso. Entrambi i lati sono bordati di mezze perle, notevole esempio di arte decorativa settecentesca."
    },
    "2": {
      "name": "FLY Caffè",
      "description": "Gusta Fly Coffee con il 50% di sconto. Al tavolo o da asporto, assapora l'aroma di ogni tazza al miglior prezzo."
    },
    "3": {
      "name": "Orologio a ripetizione",
      "description": "Orologio a ripetizione di Francis Perigal (inglese, attivo 1741–67). Cassa in oro parzialmente smaltata; quadrante smaltato bianco con numeri neri e lancette d'argento tempestate di diamanti; movimento dorato. Apice dell'arte orologiera del XVIII secolo."
    },
    "4": {
      "name": "Chitarra",
      "description": "Chitarra con fondo, fasce, manico e paletta rivestiti di chevron di tartaruga, ebano e avorio, con volute incorniciate, rombi e cenefatura geometrica. Un magistrale connubio di legni e intarsio che testimonia la straordinaria bravura dell'autore."
    },
    "5": {
      "name": "Carillon",
      "description": "Carillon svizzero del 1820 circa, a forma di mandolino. Realizzato con diversi materiali, unisce l'arte delle scatole musicali europee di inizio Ottocento all'estetica del mandolino come strumento."
    },
    "6": {
      "name": "Chitarra",
      "description": "Chitarra riccamente ornata di Giacomo (Jacob) Ertel, fine XVII secolo. Abete, ebano, legni da frutto, osso, avorio, madreperla e pergamena. L'opera fonde la passione decorativa del maestro tedesco con la tradizione liutaria italiana."
    },
    "7": {
      "name": "Mattina d'inverno in campagna",
      "description": "Litografia colorata a mano dello studio Currier & Ives, 1873. Scena rurale innevata: una slitta trainata da due cavalli porta una coppia e quattro grandi bidoni del latte; in lontananza la fattoria. Tipico genere popolare dell'Ottocento americano."
    },
    "8": {
      "name": "Datemi la libertà o datemi la morte!",
      "description": "Litografia colorata a mano Currier & Ives, 1876, \"Datemi la libertà o datemi la morte!\". Ritrae Patrick Henry che pronuncia il celebre discorso sui diritti delle colonie davanti all'Assemblea della Virginia riunita a Richmond, marzo 1775."
    },
    "9": {
      "name": "Carillon",
      "description": "Carillon svizzero oblungo in oro e smalto, circa 1820. Bordi smaltati in blu e giallo; il coperchio reca una miniatura classica smaltata circondata da mezze perle. Sintesi perfetta tra arte dei carillon e gioielleria."
    },
    "10": {
      "name": "Cassa di orologio",
      "description": "Cassa d'orologio di George Harrison, circa 1770. Oro parzialmente smaltato; la cassa esterna è incastonata di diamanti scintillanti, testimonianza della maestria di orologiai e gioiellieri britannici del XVIII secolo."
    },
    "11": {
      "name": "Viola da gamba",
      "description": "Viola da division di Richard Meares, circa 1680. Abete, ebano, acero. Le viole, i più apprezzati strumenti ad arco del tardo Rinascimento, furono gradualmente sostituite dal violino; testimonianza chiave della storia musicale."
    },
    "12": {
      "name": "Drago",
      "description": "Drago in bronzo dei primi del Seicento, opera di Giacomo Laurenziani. Al momento dell'acquisizione era catalogato come grifone, ma James Parker lo reidentificò correttamente come drago a partire dagli anni Cinquanta; splendido esempio di scultura barocca."
    },
    "13": {
      "name": "Rose e gigli",
      "description": "Henri Fantin-Latour, 1888, olio su tela. Quest'opera, in ottimo stato, mostra la virtuosa manipolazione del pigmento del pittore: usa non solo il pennello, ma anche l'estremità del manico per modellare rose e gigli con luce e texture squisite."
    },
    "14": {
      "name": "Orologio",
      "description": "Orologio di F. L. Meybom, circa 1670–75. Cassa in oro, acciaio azzurrato, cristallo di rocca, argento parzialmente dorato e diamanti; quadrante in smalto dipinto e basse-taille su oro; movimento in ottone dorato e acciaio azzurrato parziale."
    },
    "15": {
      "name": "Spilla libellula",
      "description": "Spilla libellula Art Nouveau di Edgar Bense, circa 1890. Oro, diamanti e smalto. Le ali delicate in plique-à-jour coronano una libellula finemente modellata, incarnando la moda e la gioielleria Art Nouveau e l'estetica naturalistica."
    },
    "16": {
      "name": "Bracciale",
      "description": "Bracciale indiano (bazuband), XIX secolo. Oro intrecciato incastonato di rubini e un diamante taglio rosa. Esempi simili si trovano nella tradizione della gioielleria aristocratica indiana, erede dell'estetica di corte mogol."
    },
    "17": {
      "name": "Guarnitura di armatura di George Clifford",
      "description": "Guarnizione di armatura realizzata da Jacob Halder nel 1586 presso l'Armeria Reale di Greenwich per George Clifford. Acciaio, oro, cuoio e tessuto. Clifford (1558–1605) fu nominato Campione della Regina nel 1590 e Cavaliere della Giarrettiera lo stesso anno."
    },
    "18": {
      "name": "Spilla a forma di testa di gufo",
      "description": "Spilla a testa di gufo di Castellani, circa 1860. Oro e agata. Quest'opera e il gruppo cui appartiene (cfr. 2014.713.1–.10) riflettono il forte interesse dell'Ottocento per gli stili storici e incarnano la gioielleria del revival archeologico."
    },
    "19": {
      "name": "Orologio",
      "description": "Orologio di Charles Bobinet, circa 1655–60. Cassa in agata con montature in oro smaltato; quadrante smaltato bianco con lancetta d'oro; movimento in ottone dorato e acciaio azzurrato parziale. Mostra l'alta orologeria europea di metà Seicento."
    },
    "20": {
      "name": "Iris",
      "description": "Vincent van Gogh, 1890, olio su tela. I celebri Iris. Una delle opere più emblematiche dell'ultima fase dell'artista, che con colori rigogliosi e pennellate vibranti rende omaggio profondo alla bellezza della natura."
    },
    "21": {
      "name": "Zuccheriera con coperchio",
      "description": "Zuccheriera con coperchio di Giovacchino Belli, circa 1811–22. Argento dorato. La versione Impero di Belli risulta più rilassata e intima dell'interpretazione francese coeva, ammorbidendo le linee neoclassiche con un sapore tipicamente italiano."
    },
    "22": {
      "name": "Brocca",
      "description": "Brocca in argento dorato e smalto, circa 1600. Il corpo è decorato con una processione di figure e animali, rappresentante il Trionfo di Cesare al ritorno dall'Egitto o quello di Scipione l'Africano dopo la vittoria su Annibale; capolavoro dell'arte metallica tardorinascimentale."
    },
    "23": {
      "name": "L'attore Asao Gakujūrō I nei panni di Mashiba Hisatsugu",
      "description": "Xilografia di Shunkōsai Hokushū (Osaka), 1822. Nishiki-e su carta con inchiostro e colori, formato ōban verticale giapponese. Raffigura l'attore kabuki Asao Gakujūrō I nel ruolo di Mashiba Hisatsugu con sguardo feroce e posa di sfida di grande drammaticità."
    },
    "24": {
      "name": "Corona delle Ande",
      "description": "\"Corona delle Ande\" — diadema circa 1660 e archi circa 1770. Colombiana, di Popayán. Oro sbalzato e cesellato con smeraldi. Una delle più importanti oreficerie del periodo coloniale sudamericano, sintesi creativa di tecniche europee e autoctone."
    }
  },
