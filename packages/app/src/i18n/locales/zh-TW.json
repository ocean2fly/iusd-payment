  "giftBox": {
    "1": {
      "name": "音樂盒",
      "description": "金與琺瑯製成的盾形吊墜。一面是帶水車的自動裝置農場場景，生動展現田園生活；另一面是紅底玫瑰圖案。兩面邊緣均以半珍珠精心鑲嵌，工藝精湛。"
    },
    "2": {
      "name": "FLY 咖啡",
      "description": "暢飲 FLY 咖啡，五折優惠。無論內用外帶，都能享受超值折扣，品嘗每一杯的醇香。"
    },
    "3": {
      "name": "三問懷錶",
      "description": "由英國著名製錶師 Francis Perigal（活躍於 1741–67 年）製作的打簧錶。錶殼為局部琺瑯裝飾的金質，白色琺瑯錶盤，黑色數字，鑲嵌鑽石的銀質指針；機芯鍍金。打簧錶是 18 世紀製錶工藝的巔峰之作。"
    },
    "4": {
      "name": "吉他",
      "description": "吉他背板、側板、琴頸和琴頭覆蓋玳瑁、烏木和象牙製成的雪紋圖案，並以捲草紋、菱形和幾何圖案鑲邊。這件樂器是奢華裝飾藝術與精湛木工技藝的完美結合，體現了製作者的高超造詣。"
    },
    "5": {
      "name": "音樂盒",
      "description": "約 1820 年的瑞士音樂盒，造型為曼陀林。採用多種材料精心製作，融合了 19 世紀初歐洲音樂盒工藝與曼陀林樂器造型美學。"
    },
    "6": {
      "name": "吉他",
      "description": "由 Giacomo（又名 Jacob）Ertel 於 17 世紀末製作的極其華麗的吉他。材料包括雲杉、烏木、果木、骨、象牙、珍珠母和羊皮紙。這件樂器結合了德意志工匠對奢華裝飾的追求與義大利製琴傳統，是吉他製作史上的精品。"
    },
    "7": {
      "name": "鄉村冬日清晨",
      "description": "Currier & Ives 工作室於 1873 年出品的手工上色石版畫。畫面描繪了雪景中的鄉村景象：兩匹馬牽引的雪橇上坐著一對夫妻和四個大奶罐；遠處是他們的農舍。這是 19 世紀美國典型的風俗畫，展現田園牧歌式的生活。"
    },
    "8": {
      "name": "不自由毋寧死！",
      "description": "Currier & Ives 工作室於 1876 年出品的手工上色石版畫《不自由毋寧死！》。描繪了 1775 年 3 月在里奇蒙召開的維吉尼亞議會上，Patrick Henry 發表關於殖民地權利的著名演說的場景，是美國獨立運動的經典圖像。"
    },
    "9": {
      "name": "音樂盒",
      "description": "約 1820 年瑞士製長方形金琺瑯音樂盒。邊緣以藍黃兩色琺瑯裝飾；盒蓋鑲嵌了一幅琺瑯古典微繪作品，周圍環繞半顆珍珠的精緻鑲邊。音樂盒工藝與珠寶工藝在此完美融合。"
    },
    "10": {
      "name": "錶殼",
      "description": "由 George Harrison 製作的錶殼，約 1770 年。局部琺瑯裝飾的金質錶殼，外殼則鑲嵌了璀璨的鑽石，體現了 18 世紀英國製錶與珠寶匠人的卓越技藝。"
    },
    "11": {
      "name": "分奏維奧爾琴",
      "description": "Richard Meares 約 1680 年製作的大型維奧琴（Division Viol）。以雲杉、烏木和楓木製成。維奧琴是文藝復興晚期最受推崇的弓弦樂器，在 17 世紀逐漸被提琴取代，是音樂史上的重要見證。"
    },
    "12": {
      "name": "龍",
      "description": "17 世紀初由 Giacomo Laurenziani 創作的青銅龍。收購時被歸類為獅鷲，直到 1950 年代後 James Parker 才正確辨認出它是龍，是巴洛克雕塑的精彩實例。"
    },
    "13": {
      "name": "玫瑰與百合",
      "description": "Henri Fantin-Latour 於 1888 年創作的布面油畫。這幅保存完好的畫作展示了藝術家爐火純青的油畫技法：他不僅用畫筆，還用畫筆的末端來塑造筆觸；玫瑰與百合的靜物呈現出細膩的光影與質感。"
    },
    "14": {
      "name": "懷錶",
      "description": "F. L. Meybom 約 1670–75 年製作的懷錶。錶殼由黃金、藍鋼、水晶以及部分鍍金銀和鑽石構成；錶盤採用繪畫琺瑯和低嵌琺瑯工藝於金上製作；機芯為鍍金黃銅與部分藍鋼，是 17 世紀歐洲製錶藝術的傑作。"
    },
    "15": {
      "name": "蜻蜓胸針",
      "description": "Edgar Bense 約 1890 年創作的蜻蜓胸針。以金、鑽石和琺瑯製成。這隻精巧的蜻蜓搭配細膩的空窗琺瑯翅膀，是新藝術運動時尚與珠寶工藝的典範之作，充分體現了自然主義美學。"
    },
    "16": {
      "name": "臂環",
      "description": "歸屬於 19 世紀印度的臂飾（bazuband）。以編織金絲製成，鑲嵌紅寶石和一顆玫瑰式切割鑽石。類似作品可在印度貴族珠寶傳統中找到，是蒙兀兒宮廷美學的延續。"
    },
    "17": {
      "name": "喬治·克利福德的盔甲套裝",
      "description": "Jacob Halder 於 1586 年在格林威治皇家軍械庫為 George Clifford 製作的鎧甲。鋼、金、皮革和織物。Clifford（1558–1605）於 1590 年被任命為女王侍衛，同年被授予嘉德勳章，這副鎧甲是伊莉莎白時代騎士精神的象徵。"
    },
    "18": {
      "name": "貓頭鷹頭形胸針",
      "description": "Castellani 約 1860 年製作的貓頭鷹頭形胸針。以金與瑪瑙製成。這件作品及其所屬系列反映了 19 世紀歐洲對歷史風格的濃厚興趣，是考古復興風格珠寶的代表。"
    },
    "19": {
      "name": "懷錶",
      "description": "Charles Bobinet 約 1655–60 年製作的懷錶。錶殼為瑪瑙，配以琺瑯金飾；錶盤為白色琺瑯配金質指針；機芯為鍍金黃銅和部分藍鋼，展現了 17 世紀中葉歐洲製錶業的高超技藝。"
    },
    "20": {
      "name": "鳶尾花",
      "description": "Vincent van Gogh 於 1890 年創作的布面油畫，即著名的《鳶尾花》。這是梵谷晚期最具代表性的作品之一，以豐富的色彩、充滿生命力的筆觸，展現他對自然之美的深情禮讚。"
    },
    "21": {
      "name": "帶蓋糖罐",
      "description": "Giovacchino Belli 約 1811–22 年製作的帶蓋糖碗。銀鍍金。Belli 版本的帝國風格在此顯得比同時代法國版本更舒緩、親切，柔化了嚴謹的新古典主義線條，別具義大利風情。"
    },
    "22": {
      "name": "水瓶",
      "description": "約 1600 年製作的銀鍍金琺瑯水罐。器身裝飾著遊行人物和動物的浮雕，可能表現凱撒從埃及歸來的凱旋或西庇阿·阿非利加努斯的凱旋遊行，是文藝復興晚期金屬工藝的華彩之作。"
    },
    "23": {
      "name": "飾演真柴久次的歌舞伎演員初代淺尾奧十郎",
      "description": "Shunkōsai Hokushū（春好齋北洲）1822 年創作的木版浮世繪（錦繪）。以紙本水墨設色，採用日本大判豎幅。描繪大阪歌舞伎演員淺尾岳十郎 I 飾演馬柴久次的形象，他怒目圓睜，擺出挑釁的姿態，極具戲劇張力。"
    },
    "24": {
      "name": "安第斯皇冠",
      "description": "《安地斯之冠》——冠體約 1660 年，拱架約 1770 年。來自哥倫比亞波帕揚。採用金錘揲和鐫花工藝，鑲嵌祖母綠。這件冠冕是南美殖民時期最重要的金銀器之一，展現了新大陸工匠對歐洲與本土工藝的創造性融合。"
    }
  },
