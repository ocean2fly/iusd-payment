  "giftBox": {
    "1": {
      "name": "Kotak musik",
      "description": "Liontin berbentuk perisai dari emas dan enamel. Satu sisi menampilkan adegan peternakan otomaton dengan kincir air; sisi lain mawar di atas latar merah. Kedua sisi dibingkai mutiara separuh, contoh istimewa seni dekoratif abad ke-18."
    },
    "2": {
      "name": "FLY Kopi",
      "description": "Nikmati Fly Coffee dengan diskon 50%. Di kafe atau dibawa pulang, rasakan aroma setiap cangkir dengan harga terbaik."
    },
    "3": {
      "name": "Jam pengulang",
      "description": "Jam pengulang buatan Francis Perigal, pembuat jam terkemuka Inggris (aktif 1741–67). Casing emas sebagian berenamel; dial enamel putih dengan angka hitam dan jarum perak bertatah berlian; mekanisme berlapis emas. Puncak seni jam abad ke-18."
    },
    "4": {
      "name": "Gitar",
      "description": "Gitar yang punggungnya, sisi, leher, dan kepalanya dilapisi pola chevron dari cangkang kura-kura, kayu eboni, dan gading, dengan lengkungan berbingkai, belah ketupat, dan pinggiran geometris. Paduan kayu dan seni inlay yang memperlihatkan keahlian luar biasa pembuatnya."
    },
    "5": {
      "name": "Kotak musik",
      "description": "Kotak musik Swiss sekitar 1820 berbentuk mandolin. Dibuat dari berbagai bahan secara teliti, memadukan seni kotak musik Eropa awal abad ke-19 dengan estetika mandolin sebagai alat musik."
    },
    "6": {
      "name": "Gitar",
      "description": "Gitar mewah karya Giacomo (Jacob) Ertel, akhir abad ke-17. Cemara, eboni, kayu buah, tulang, gading, mutiara, dan perkamen. Karya ini memadukan hasrat dekoratif pengrajin Jerman dengan tradisi pembuatan gitar Italia."
    },
    "7": {
      "name": "Pagi Musim Dingin di Desa",
      "description": "Litograf yang diwarnai tangan dari studio Currier & Ives, 1873. Pemandangan pedesaan bersalju: kereta luncur ditarik dua kuda membawa pasangan dan empat kaleng susu besar; jauh di belakang terlihat peternakan. Contoh klasik seni rakyat Amerika abad ke-19."
    },
    "8": {
      "name": "Beri Aku Kebebasan atau Kematian!",
      "description": "Litograf yang diwarnai tangan Currier & Ives, 1876, \"Beri aku kebebasan atau beri aku kematian!\". Menggambarkan Patrick Henry menyampaikan pidato terkenalnya tentang hak-hak koloni di Majelis Virginia di Richmond, Maret 1775."
    },
    "9": {
      "name": "Kotak musik",
      "description": "Kotak musik Swiss persegi panjang dari emas dan enamel, sekitar 1820. Pinggiran berenamel biru dan kuning; tutupnya berisi miniatur enamel klasik yang dikelilingi mutiara separuh. Paduan sempurna antara seni kotak musik dan pembuatan perhiasan."
    },
    "10": {
      "name": "Kotak jam",
      "description": "Casing jam buatan George Harrison, sekitar 1770. Emas sebagian berenamel; casing luarnya bertatah berlian yang berkilauan, bukti keahlian tinggi para pembuat jam dan perhiasan Inggris abad ke-18."
    },
    "11": {
      "name": "Division Viol",
      "description": "Division viol Richard Meares, sekitar 1680. Cemara, eboni, maple. Viol, instrumen gesek yang paling dihormati pada akhir masa Renaissance, secara bertahap digantikan oleh biola pada abad ke-17; saksi penting sejarah musik."
    },
    "12": {
      "name": "Naga",
      "description": "Naga perunggu awal abad ke-17 karya Giacomo Laurenziani. Saat diperoleh, dikatalogkan sebagai griffin; sejak tahun 1950-an, James Parker dengan tepat mengidentifikasinya kembali sebagai naga; contoh luar biasa patung Barok."
    },
    "13": {
      "name": "Mawar dan bunga lili",
      "description": "Henri Fantin-Latour, 1888, cat minyak di atas kanvas. Karya yang terawetkan dengan baik ini menunjukkan penguasaan pigmen yang mahir dari sang pelukis: ia tidak hanya menggunakan kuas, tetapi juga ujung gagangnya untuk membentuk mawar dan lili dengan cahaya dan tekstur halus."
    },
    "14": {
      "name": "Jam",
      "description": "Jam F. L. Meybom, sekitar 1670–75. Casing dari emas, baja biru, kristal batu, dan perak berlapis emas sebagian dengan berlian; dial dengan enamel lukis dan basse-taille pada emas; mekanisme kuningan berlapis emas dan baja sebagian biru."
    },
    "15": {
      "name": "Bros capung",
      "description": "Bros capung gaya Art Nouveau karya Edgar Bense, sekitar 1890. Emas, berlian, dan enamel. Sayap halusnya dalam teknik plique-à-jour memahkotai capung yang dipahat dengan detail, mencerminkan mode dan seni perhiasan Art Nouveau serta estetika naturalistik."
    },
    "16": {
      "name": "Gelang lengan",
      "description": "Gelang lengan India (bazuband), abad ke-19. Emas anyaman bertatah ruby dan satu berlian potongan rose. Contoh serupa terdapat dalam tradisi perhiasan aristokrat India, pewaris estetika istana Mughal."
    },
    "17": {
      "name": "Set Baju Zirah George Clifford",
      "description": "Set zirah yang dibuat oleh Jacob Halder pada 1586 di Gudang Senjata Kerajaan Greenwich untuk George Clifford. Baja, emas, kulit, dan tekstil. Clifford (1558–1605) diangkat sebagai Juara Ratu pada 1590 dan dianugerahi Pangkat Garter di tahun yang sama."
    },
    "18": {
      "name": "Bros berbentuk kepala burung hantu",
      "description": "Bros berbentuk kepala burung hantu karya Castellani, sekitar 1860. Emas dan batu akik. Karya ini dan kelompok yang dimilikinya (lihat 2014.713.1–.10) mencerminkan minat besar Eropa abad ke-19 terhadap gaya-gaya sejarah dan mewakili perhiasan kebangkitan arkeologis."
    },
    "19": {
      "name": "Jam",
      "description": "Jam Charles Bobinet, sekitar 1655–60. Casing akik dengan dudukan emas berenamel; dial enamel putih dengan jarum emas; mekanisme kuningan berlapis emas dan baja sebagian biru. Menyaksikan keahlian pembuatan jam Eropa pertengahan abad ke-17."
    },
    "20": {
      "name": "Iris",
      "description": "Vincent van Gogh, 1890, cat minyak di atas kanvas. Lukisan Irises yang terkenal. Salah satu karya paling ikonik pada fase akhir sang seniman; dengan warna yang kaya dan sapuan kuas yang hidup, ia memberi penghormatan mendalam pada keindahan alam."
    },
    "21": {
      "name": "Mangkuk gula bertutup",
      "description": "Mangkuk gula bertutup karya Giovacchino Belli, sekitar 1811–22. Perak berlapis emas. Tafsir gaya Empire Belli lebih santai dan intim dibandingkan interpretasi Prancis pada zamannya, melembutkan garis neoklasik yang tegas dengan sentuhan Italia yang khas."
    },
    "22": {
      "name": "Teko air",
      "description": "Kendi perak berlapis emas dan enamel, sekitar 1600. Badannya dihiasi arak-arakan sosok dan hewan yang menggambarkan Kemenangan Caesar saat kembali dari Mesir atau kemenangan Scipio Africanus setelah mengalahkan Hannibal; karya logam gemilang akhir Renaissance."
    },
    "23": {
      "name": "Aktor Asao Gakujūrō I sebagai Mashiba Hisatsugu",
      "description": "Cetakan kayu Shunkōsai Hokushū (Osaka), 1822. Nishiki-e di atas kertas dengan tinta dan warna, format ōban vertikal Jepang. Menggambarkan aktor kabuki Osaka Asao Gakujūrō I dalam peran Mashiba Hisatsugu dengan tatapan garang dan pose menantang yang sangat dramatis."
    },
    "24": {
      "name": "Mahkota Andes",
      "description": "\"Mahkota Andes\" — diadem sekitar 1660 dan lengkungan sekitar 1770. Kolombia, Popayán. Emas repoussé dan ukir bertatah zamrud. Salah satu karya emas terpenting masa kolonial Amerika Selatan, sintesis kreatif teknik Eropa dan pribumi."
    }
  },
