    },
    "10": {
      "name": "Watch case",
      "description": "Watch case by George Harrison, ca. 1770 — partly enameled gold, outer case set with diamonds."
    },
    "11": {
      "name": "Division Viol",
      "description": "Division Viol by Richard Meares, ca. 1680. Spruce, ebony, maple. British bowed instrument of the late Renaissance."
    },
    "12": {
      "name": "Dragon",
      "description": "Early 17th-century bronze dragon by Giacomo Laurenziani — originally catalogued as a griffin."
    },
    "13": {
      "name": "Roses and Lilies",
      "description": "Henri Fantin-Latour, 1888. Oil on canvas — a virtuosic floral still life of roses and lilies."
    },
    "14": {
      "name": "Watch",
      "description": "Watch by F. L. Meybom, ca. 1670–75. Gold and blued-steel case with rock crystal and diamonds; painted enamel dial."
    },
    "15": {
      "name": "Dragonfly brooch",
      "description": "Art Nouveau dragonfly brooch by Edgar Bense, ca. 1890. Gold, diamond, and plique-à-jour enamel wings."
    },
    "16": {
      "name": "Armlet",
      "description": "Indian armlet (bazuband), 19th c. Woven gold studded with rubies and a rose-cut diamond."
    },
    "17": {
      "name": "Armor Garniture of George Clifford",
