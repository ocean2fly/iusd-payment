    },
    "18": {
      "name": "Brooch in the form of an owl head",
      "description": "Owl-head brooch by Castellani, ca. 1860 — gold and agate, a revival-style piece of 19th-century archaeological jewelry."
    },
    "19": {
      "name": "Watch",
