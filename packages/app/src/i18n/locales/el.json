  "giftBox": {
    "1": {
      "name": "Μουσικό κουτί",
      "description": "Κρεμαστό σε σχήμα ασπίδας από χρυσό και σμάλτο. Η μία όψη απεικονίζει αυτόματη σκηνή φάρμας με νερόμυλο, η άλλη ένα τριαντάφυλλο σε κόκκινο φόντο. Και οι δύο όψεις περιβάλλονται από μισά μαργαριτάρια, δείγμα της διακοσμητικής τέχνης του 18ου αιώνα."
    },
    "2": {
      "name": "FLY Καφές",
      "description": "Απόλαυσε τον Fly Coffee με 50% έκπτωση. Στο κατάστημα ή για το πακέτο, γεύσου το άρωμα κάθε φλιτζανιού στην καλύτερη τιμή."
    },
    "3": {
      "name": "Ρολόι επανάληψης",
      "description": "Ρολόι repeater του Άγγλου ωρολογοποιού Francis Perigal (ενεργός 1741–67). Χρυσή, εν μέρει σμαλτωμένη κάσα· λευκό σμαλτωμένο καντράν με μαύρα ψηφία και ασημένιοι δείκτες με διαμάντια· επιχρυσωμένος μηχανισμός. Κορυφή της ωρολογοποιίας του 18ου αιώνα."
    },
    "4": {
      "name": "Κιθάρα",
      "description": "Κιθάρα της οποίας πλάτη, πλαϊνά, λαιμός και κεφαλή έχουν επενδυθεί με τσεβρόν από χελωνόστρακο, έβενο και ελεφαντόδοντο, με στροβιλισμούς, ρόμβους και γεωμετρικά πλαίσια. Μαστορική ένωση ξύλου και ένθετης τέχνης που αποκαλύπτει την εξαιρετική δεξιοτεχνία του κατασκευαστή."
    },
    "5": {
      "name": "Μουσικό κουτί",
      "description": "Ελβετικό μουσικό κουτί περί το 1820 σε σχήμα μαντολίνου. Κατασκευασμένο με πλήθος υλικών, συνδυάζει την τέχνη των ευρωπαϊκών μουσικών κουτιών των αρχών του 19ου αιώνα με την αισθητική του μαντολίνου ως οργάνου."
    },
    "6": {
      "name": "Κιθάρα",
      "description": "Εξαιρετικά διακοσμημένη κιθάρα του Giacomo (Jacob) Ertel, τέλη 17ου αιώνα. Έλατο, έβενος, οπωροφόρα, οστό, ελεφαντόδοντο, μαργαριταρόστρακο και περγαμηνή. Το έργο ενώνει το πάθος του Γερμανού τεχνίτη για διακόσμηση με την ιταλική παράδοση κατασκευής κιθάρας."
    },
    "7": {
      "name": "Χειμερινό πρωινό στην ύπαιθρο",
      "description": "Χρωματισμένη στο χέρι λιθογραφία του εργαστηρίου Currier & Ives, 1873. Χιονισμένη αγροτική σκηνή: ένα έλκηθρο που τραβούν δύο άλογα μεταφέρει ένα ζευγάρι και τέσσερα μεγάλα δοχεία γάλακτος· στο βάθος η φάρμα. Τυπικό δείγμα του λαϊκού είδους στην Αμερική του 19ου αιώνα."
    },
    "8": {
      "name": "Ή ελευθερία ή θάνατος!",
      "description": "Χρωματισμένη στο χέρι λιθογραφία Currier & Ives, 1876, \"Δώστε μου ελευθερία ή δώστε μου θάνατο!\". Απεικονίζει τον Patrick Henry να εκφωνεί τον περίφημο λόγο του για τα δικαιώματα των αποικιών ενώπιον της Συνέλευσης της Βιρτζίνια στο Ρίτσμοντ, Μάρτιος 1775."
    },
    "9": {
      "name": "Μουσικό κουτί",
      "description": "Ελβετικό επίμηκες μουσικό κουτί από χρυσό και σμάλτο, γύρω στο 1820. Περιθώρια σε μπλε και κίτρινο σμάλτο· στο καπάκι κλασική σμαλτωμένη μινιατούρα περιτριγυρισμένη από μισά μαργαριτάρια. Άψογη σύνθεση τέχνης μουσικού κουτιού και κοσμηματοποιίας."
    },
    "10": {
      "name": "Θήκη ρολογιού",
      "description": "Θήκη ρολογιού του George Harrison, γύρω στο 1770. Εν μέρει σμαλτωμένος χρυσός· η εξωτερική θήκη είναι διακοσμημένη με λαμπερά διαμάντια, μαρτυρία της υψηλής δεξιοτεχνίας Βρετανών ωρολογοποιών και κοσμηματοποιών του 18ου αιώνα."
    },
    "11": {
      "name": "Division Viol",
      "description": "Division viol του Richard Meares, γύρω στο 1680. Έλατο, έβενος, σφενδάμι. Τα viol, τα πιο εκτιμώμενα έγχορδα τοξωτά όργανα της ύστερης Αναγέννησης, αντικαταστάθηκαν σταδιακά από το βιολί τον 17ο αιώνα. Σημαντικός μάρτυρας της μουσικής ιστορίας."
    },
    "12": {
      "name": "Δράκος",
      "description": "Χάλκινος δράκος των αρχών του 17ου αιώνα, έργο του Giacomo Laurenziani. Κατά την απόκτηση καταγράφηκε ως γρύπας, αλλά μετά τη δεκαετία του 1950 ο James Parker τον επαναταυτοποίησε σωστά ως δράκο· εξαιρετικό δείγμα μπαρόκ γλυπτικής."
    },
    "13": {
      "name": "Τριαντάφυλλα και κρίνα",
      "description": "Henri Fantin-Latour, 1888, λάδι σε καμβά. Το έργο που διατηρείται σε εξαιρετική κατάσταση αποκαλύπτει τον δεξιοτεχνικό χειρισμό του χρώματος: χρησιμοποιεί όχι μόνο το πινέλο αλλά και την άκρη της λαβής για να πλάθει τριαντάφυλλα και κρίνους με εξαίσιο φως και υφή."
    },
    "14": {
      "name": "Ρολόι",
      "description": "Ρολόι F. L. Meybom, γύρω στο 1670–75. Κάσα από χρυσό, μπλε ατσάλι, κρύσταλλο βράχου και εν μέρει επιχρυσωμένο ασήμι με διαμάντια· καντράν με ζωγραφιστό σμάλτο και basse-taille σε χρυσό· μηχανισμός από επιχρυσωμένο ορείχαλκο και εν μέρει μπλε ατσάλι."
    },
    "15": {
      "name": "Καρφίτσα λιβελούλας",
      "description": "Αρ Νουβό καρφίτσα λιβελούλας του Edgar Bense, γύρω στο 1890. Χρυσός, διαμάντια και σμάλτο. Οι λεπτές πτέρυγες σε τεχνική plique-à-jour στεφανώνουν μια εξαιρετικά δουλεμένη λιβελούλα, ενσαρκώνοντας τη μόδα και την κοσμηματοποιία του Αρ Νουβό και τη φυσιοκρατική αισθητική."
    },
    "16": {
      "name": "Βραχιόλι",
      "description": "Ινδικό βραχιόλι (bazuband), 19ος αιώνας. Πλεκτός χρυσός με ρουμπίνια και ένα διαμάντι rose-cut. Παρόμοια παραδείγματα εμφανίζονται στην παράδοση της αριστοκρατικής ινδικής κοσμηματοποιίας, κληρονόμου της αυλικής αισθητικής των Μογγόλων."
    },
    "17": {
      "name": "Πανοπλία του George Clifford",
      "description": "Πανοπλία που κατασκεύασε ο Jacob Halder το 1586 στο Βασιλικό Οπλοστάσιο του Γκρίνουιτς για τον George Clifford. Ατσάλι, χρυσός, δέρμα και ύφασμα. Ο Clifford (1558–1605) διορίστηκε Πρωταθλητής της Βασίλισσας το 1590 και βραβεύτηκε με το Τάγμα της Κάλτσας την ίδια χρονιά."
    },
    "18": {
      "name": "Καρφίτσα σε σχήμα κεφαλιού κουκουβάγιας",
      "description": "Καρφίτσα σε σχήμα κεφαλιού κουκουβάγιας του Castellani, γύρω στο 1860. Χρυσός και αχάτης. Το έργο και η ομάδα στην οποία ανήκει (βλ. 2014.713.1–.10) αντανακλούν το έντονο ενδιαφέρον του 19ου αιώνα για ιστορικά στυλ και ενσαρκώνουν την κοσμηματοποιία της αρχαιολογικής αναβίωσης."
    },
    "19": {
      "name": "Ρολόι",
      "description": "Ρολόι του Charles Bobinet, γύρω στο 1655–60. Κάσα από αχάτη με εξαρτήματα σμαλτωμένου χρυσού· λευκό σμαλτωμένο καντράν με χρυσό δείκτη· μηχανισμός από επιχρυσωμένο ορείχαλκο και εν μέρει μπλε ατσάλι. Μαρτυρεί την ευρωπαϊκή ωρολογοποιία των μέσων του 17ου αιώνα."
    },
    "20": {
      "name": "Ίριδες",
      "description": "Vincent van Gogh, 1890, λάδι σε καμβά. Τα περίφημα Κρινάκια. Ένα από τα πιο εμβληματικά έργα της τελευταίας περιόδου του καλλιτέχνη· με πλούσια χρώματα και ζωντανές πινελιές αποτίει βαθύ φόρο τιμής στην ομορφιά της φύσης."
    },
    "21": {
      "name": "Ζαχαριέρα με καπάκι",
      "description": "Ζαχαριέρα με καπάκι του Giovacchino Belli, γύρω στο 1811–22. Επιχρυσωμένο ασήμι. Η ερμηνεία του ρυθμού Αυτοκρατορίας από τον Belli δείχνει πιο χαλαρή και οικεία από τη σύγχρονή της γαλλική, μαλακώνοντας τις αυστηρές νεοκλασικές γραμμές με ιταλικό χαρακτήρα."
    },
    "22": {
      "name": "Κανάτα",
      "description": "Κανάτα από επιχρυσωμένο ασήμι και σμάλτο, γύρω στο 1600. Το σώμα της διακοσμείται με πομπή προσώπων και ζώων που απεικονίζει είτε τον Θρίαμβο του Καίσαρα από την Αίγυπτο είτε του Σκιπίωνα Αφρικανού μετά την ήττα του Αννίβα· εξαιρετικό δείγμα μεταλλοτεχνίας της ύστερης Αναγέννησης."
    },
    "23": {
      "name": "Ο ηθοποιός Asao Gakujūrō I ως Mashiba Hisatsugu",
      "description": "Ξυλογραφία Shunkōsai Hokushū (Οσάκα), 1822. Nishiki-e σε χαρτί με μελάνι και χρώμα, ιαπωνικό ōban κατακόρυφο φορμάτ. Απεικονίζει τον ηθοποιό του καμπουκί της Οσάκα Asao Gakujūrō I στον ρόλο του Mashiba Hisatsugu με άγριο βλέμμα και προκλητική πόζα γεμάτη δραματικότητα."
    },
    "24": {
      "name": "Το Στέμμα των Άνδεων",
      "description": "\"Κορώνα των Άνδεων\" — διάδημα γύρω στο 1660 και αψίδες γύρω στο 1770. Κολομβία, Popayán. Ρεπουσέ και σμιλεμένος χρυσός με σμαράγδια. Ένα από τα σημαντικότερα χρυσοχοϊκά έργα της αποικιακής περιόδου της Νότιας Αμερικής· δημιουργική σύνθεση ευρωπαϊκών και ιθαγενών τεχνικών."
    }
  },
