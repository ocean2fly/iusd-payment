  "giftBox": {
    "1": {
      "name": "音乐盒",
      "description": "金与珐琅制成的盾形吊坠。一面是带水车的自动装置农场场景，生动展现田园生活；另一面是红底玫瑰图案。两面边缘均以半珍珠精心镶嵌，工艺精湛。"
    },
    "2": {
      "name": "FLY 咖啡",
      "description": "畅饮 FLY 咖啡，五折优惠。无论堂食外带，都能尊享超值折扣，品尝每一杯的醇香。"
    },
    "3": {
      "name": "三问怀表",
      "description": "由英国著名制表师 Francis Perigal（活跃于 1741–67 年）制作的打簧表。表壳为局部珐琅装饰的金质，白色珐琅表盘，黑色数字，镶嵌钻石的银质指针；机芯镀金。打簧表是 18 世纪制表工艺的巅峰之作。"
    },
    "4": {
      "name": "吉他",
      "description": "吉他背板、侧板、琴颈和琴头覆盖玳瑁、乌木和象牙制成的雪纹图案，并以卷草纹、菱形和几何图案镶边。这件乐器是奢华装饰艺术与精湛木工技艺的完美结合，体现了制作者的高超造诣。"
    },
    "5": {
      "name": "音乐盒",
      "description": "约 1820 年的瑞士音乐盒，造型为曼陀林。采用多种材料精心制作，融合了 19 世纪初欧洲音乐盒工艺与曼陀林乐器造型美学。"
    },
    "6": {
      "name": "吉他",
      "description": "由 Giacomo（又名 Jacob）Ertel 于 17 世纪末制作的极其华丽的吉他。材料包括云杉、乌木、果木、骨、象牙、珍珠母和羊皮纸。这件乐器结合了德意志工匠对奢华装饰的追求与意大利制琴传统，是吉他制作史上的精品。"
    },
    "7": {
      "name": "乡村冬日清晨",
      "description": "Currier & Ives 工作室于 1873 年出品的手工上色石版画。画面描绘了雪景中的乡村景象：两匹马牵引的雪橇上坐着一对夫妇和四个大奶罐；远处是他们的农舍。这是 19 世纪美国典型的风俗画，展现田园牧歌式的生活。"
    },
    "8": {
      "name": "不自由毋宁死！",
      "description": "Currier & Ives 工作室于 1876 年出品的手工上色石版画《不自由毋宁死！》。描绘了 1775 年 3 月在里士满召开的弗吉尼亚议会上，Patrick Henry 发表关于殖民地权利的著名演说的场景，是美国独立运动的经典图像。"
    },
    "9": {
      "name": "音乐盒",
      "description": "约 1820 年瑞士制长方形金珐琅音乐盒。边缘以蓝黄两色珐琅装饰；盒盖镶嵌了一幅珐琅古典微绘作品，周围环绕半颗珍珠的精致镶边。音乐盒工艺与珠宝工艺在此完美融合。"
    },
    "10": {
      "name": "表壳",
      "description": "由 George Harrison 制作的表壳，约 1770 年。局部珐琅装饰的金质表壳，外壳则镶嵌了璀璨的钻石，体现了 18 世纪英国制表与珠宝匠人的卓越技艺。"
    },
    "11": {
      "name": "分奏维奥尔琴",
      "description": "Richard Meares 约 1680 年制作的大型维奥琴（Division Viol）。以云杉、乌木和枫木制成。维奥琴是文艺复兴晚期最受推崇的弓弦乐器，在 17 世纪逐渐被提琴取代，是音乐史上的重要见证。"
    },
    "12": {
      "name": "龙",
      "description": "17 世纪初由 Giacomo Laurenziani 创作的青铜龙。收购时被归类为狮鹫，直到 1950 年代后 James Parker 才正确辨认出它是龙，是巴洛克雕塑的精彩实例。"
    },
    "13": {
      "name": "玫瑰与百合",
      "description": "Henri Fantin-Latour 于 1888 年创作的布面油画。这幅保存完好的画作展示了艺术家炉火纯青的油画技法：他不仅用画笔，还用画笔的末端来塑造笔触；玫瑰与百合的静物呈现出细腻的光影与质感。"
    },
    "14": {
      "name": "怀表",
      "description": "F. L. Meybom 约 1670–75 年制作的怀表。表壳由黄金、蓝钢、水晶以及部分镀金银和钻石构成；表盘采用绘画珐琅和低嵌珐琅工艺于金上制作；机芯为镀金黄铜与部分蓝钢，是 17 世纪欧洲制表艺术的杰作。"
    },
    "15": {
      "name": "蜻蜓胸针",
      "description": "Edgar Bense 约 1890 年创作的蜻蜓胸针。以金、钻石和珐琅制成。这只精巧的蜻蜓搭配细腻的空窗珐琅翅膀，是新艺术运动时尚与珠宝工艺的典范之作，充分体现了自然主义美学。"
    },
    "16": {
      "name": "臂环",
      "description": "归属于 19 世纪印度的臂饰（bazuband）。以编织金丝制成，镶嵌红宝石和一颗玫瑰式切割钻石。类似作品可在印度贵族珠宝传统中找到，是莫卧儿宫廷美学的延续。"
    },
    "17": {
      "name": "乔治·克利福德的盔甲套装",
      "description": "Jacob Halder 于 1586 年在格林尼治皇家军械库为 George Clifford 制作的铠甲。钢、金、皮革和织物。Clifford（1558–1605）于 1590 年被任命为女王侍卫，同年被授予嘉德勋章，这副铠甲是伊丽莎白时代骑士精神的象征。"
    },
    "18": {
      "name": "猫头鹰头形胸针",
      "description": "Castellani 约 1860 年制作的猫头鹰头形胸针。以金与玛瑙制成。这件作品及其所属系列反映了 19 世纪欧洲对历史风格的浓厚兴趣，是考古复兴风格珠宝的代表。"
    },
    "19": {
      "name": "怀表",
      "description": "Charles Bobinet 约 1655–60 年制作的怀表。表壳为玛瑙，配以珐琅金饰；表盘为白色珐琅配金质指针；机芯为镀金黄铜和部分蓝钢，展现了 17 世纪中叶欧洲制表业的高超技艺。"
    },
    "20": {
      "name": "鸢尾花",
      "description": "Vincent van Gogh 于 1890 年创作的布面油画，即著名的《鸢尾花》。这是梵高晚期最具代表性的作品之一，以丰富的色彩、充满生命力的笔触，展现他对自然之美的深情礼赞。"
    },
    "21": {
      "name": "带盖糖罐",
      "description": "Giovacchino Belli 约 1811–22 年制作的带盖糖碗。银镀金。Belli 版本的帝国风格在此显得比同时代法国版本更舒缓、亲切，柔化了严谨的新古典主义线条，别具意大利风情。"
    },
    "22": {
      "name": "水瓶",
      "description": "约 1600 年制作的银镀金珐琅水罐。器身装饰着游行人物和动物的浮雕，可能表现凯撒从埃及归来的凯旋或西庇阿·阿非利加的凯旋游行，是文艺复兴晚期金属工艺的华彩之作。"
    },
    "23": {
      "name": "饰演真柴久次的歌舞伎演员初代浅尾奥十郎",
      "description": "Shunkōsai Hokushū（春好斋北洲）1822 年创作的木版浮世绘（锦绘）。以纸本水墨设色，采用日本大判竖幅。描绘大阪歌舞伎演员浅尾岳十郎 I 饰演马柴久次的形象，他怒目圆睁，摆出挑衅的姿态，极具戏剧张力。"
    },
    "24": {
      "name": "安第斯皇冠",
      "description": "《安第斯之冠》——冠体约 1660 年，拱架约 1770 年。来自哥伦比亚波帕扬。采用金锤揲和镌花工艺，镶嵌祖母绿。这件冠冕是南美殖民时期最重要的金银器之一，展现了新大陆工匠对欧洲与本土工艺的创造性融合。"
    }
  },
