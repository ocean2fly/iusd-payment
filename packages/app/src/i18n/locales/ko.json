  "giftBox": {
    "1": {
      "name": "뮤직박스",
      "description": "금과 에나멜로 제작된 방패 형태 펜던트. 한 면에는 물레방아가 있는 오토마톤 농장 장면이, 다른 면에는 빨간 배경의 장미가 표현되어 있으며, 양면 모두 반 진주로 정교하게 테두리를 장식했다."
    },
    "2": {
      "name": "FLY 커피",
      "description": "FLY 커피를 50% 할인으로 즐겨보세요. 매장에서나 포장으로나, 각 잔의 풍부한 향을 더욱 저렴하게 만끽할 수 있습니다."
    },
    "3": {
      "name": "리피터 시계",
      "description": "영국의 저명한 시계 제작자 Francis Perigal(1741–67 활동) 제작 리피터 시계. 부분 에나멜의 금제 케이스, 흰 에나멜 다이얼에 검은 숫자, 다이아몬드 세팅 은 바늘; 도금 무브먼트. 18세기 시계 공예의 정점."
    },
    "4": {
      "name": "기타",
      "description": "거북딱지, 흑단, 상아로 된 쉐브런 문양과 스크롤워크, 마름모, 기하학적 테두리를 품은 기타. 뒤판·측판·네크·헤드 전체에 상감이 들어간, 나무와 장식예술이 결합된 거장의 걸작."
    },
    "5": {
      "name": "뮤직박스",
      "description": "약 1820년 스위스제 만돌린 형태 뮤직박스. 다양한 소재로 정교하게 제작되어 19세기 초 유럽 뮤직박스 공예와 만돌린 악기 조형미가 어우러진 작품."
    },
    "6": {
      "name": "기타",
      "description": "Giacomo(별칭 Jacob) Ertel이 17세기 말 제작한 극도로 화려한 기타. 가문비·흑단·과수목·뼈·상아·자개·양피지를 사용. 독일 장인의 장식에 대한 집착과 이탈리아 제작 전통이 결합된 명품."
    },
    "7": {
      "name": "시골의 겨울 아침",
      "description": "Currier & Ives 공방 1873년 발행의 손 채색 석판화. 눈 덮인 시골 풍경: 두 마리 말이 끄는 썰매에 부부와 네 개의 큰 우유통; 저 멀리 농가. 19세기 미국의 전형적인 풍속화로 목가적 생활을 묘사."
    },
    "8": {
      "name": "자유가 아니면 죽음을!",
      "description": "Currier & Ives 공방 1876년 발행의 손 채색 석판화 \"자유가 아니면 죽음을!\". 1775년 3월 리치몬드 버지니아 의회에서 패트릭 헨리가 식민지의 권리에 대해 유명한 연설을 하는 장면을 묘사한, 독립운동의 상징적 이미지."
    },
    "9": {
      "name": "뮤직박스",
      "description": "스위스제 약 1820년 직사각형 금·에나멜 뮤직박스. 가장자리를 파랑과 노랑 에나멜로 장식하고, 뚜껑에는 고전적 에나멜 미니어처가 박혀 반 진주로 섬세하게 테두리를 돌렸다. 뮤직박스와 보석 공예의 완벽한 융합."
    },
    "10": {
      "name": "시계 케이스",
      "description": "George Harrison 제작, 약 1770년의 시계 케이스. 부분 에나멜 금제, 외부 케이스에는 다이아몬드가 세팅되어 찬란하게 빛난다. 18세기 영국의 시계 장인과 보석 세공사의 뛰어난 기술이 결집된 작품."
    },
    "11": {
      "name": "디비전 비올",
      "description": "Richard Meares가 약 1680년에 제작한 대형 디비전 비올. 가문비·흑단·단풍 사용. 디비전 비올은 르네상스 말기 가장 존중받던 활악기로, 17세기에 걸쳐 점차 바이올린에 자리를 내주었다. 음악사의 중요한 증거물."
    },
    "12": {
      "name": "드래곤",
      "description": "17세기 초 Giacomo Laurenziani가 제작한 청동 용. 입수 당시에는 그리핀으로 분류되었으나, 1950년대 이후 James Parker에 의해 용으로 올바르게 재확인된 바로크 조각의 걸작."
    },
    "13": {
      "name": "장미와 백합",
      "description": "Henri Fantin-Latour 1888년 작, 캔버스에 유채. 보존 상태가 매우 좋은 이 작품은 화가의 원숙한 회화 기법을 보여준다: 붓뿐 아니라 붓자루 끝으로도 물감을 다루는 섬세한 손길로 장미와 백합을 탁월하게 묘사했다."
    },
    "14": {
      "name": "시계",
      "description": "F. L. Meybom 약 1670–75년 제작 회중시계. 케이스는 금·청열 강철·수정·부분 도금 은과 다이아몬드로 구성; 페인티드 에나멜과 바세타이유 에나멜을 금 위에 시공한 다이얼; 도금 황동과 부분 청열 강철의 무브먼트."
    },
    "15": {
      "name": "잠자리 브로치",
      "description": "Edgar Bense 약 1890년 작 아르누보 잠자리 브로치. 금·다이아몬드·에나멜. 정교하게 조형된 잠자리에 섬세한 플리카주르 에나멜 날개를 갖춘, 아르누보 패션과 보석 공예의 본보기이자 자연주의 미학의 구현."
    },
    "16": {
      "name": "팔찌",
      "description": "19세기 인도의 팔찌(바주반드)로 추정. 짠 금에 루비와 로즈컷 다이아몬드를 박아 장식. 무굴 궁정 미학을 계승한 귀족 보석 전통에서 유사한 예를 찾을 수 있다."
    },
    "17": {
      "name": "조지 클리포드의 갑옷 세트",
      "description": "Jacob Halder가 1586년 그리니치 왕립 무기고에서 George Clifford를 위해 제작한 갑주 일습. 강철·금·가죽·직물. Clifford(1558–1605)는 1590년 여왕의 챔피언으로 임명되었고 같은 해 가터 훈장을 받았으며, 이 갑옷은 엘리자베스 시대 기사도의 상징이다."
    },
    "18": {
      "name": "부엉이 머리 모양 브로치",
      "description": "Castellani 약 1860년 제작의 올빼미 머리 모양 브로치. 금과 마노로 제작. 이 작품과 속한 그룹(2014.713.1–.10 참조)은 19세기 유럽의 역사적 양식에 대한 강한 관심을 반영하는 고고학적 부흥 양식 보석의 대표작."
    },
    "19": {
      "name": "시계",
      "description": "Charles Bobinet 약 1655–60년 작 회중시계. 마노 케이스에 에나멜 금 장식; 흰 에나멜 다이얼에 금 바늘; 도금 황동과 부분 청열 강철 무브먼트. 17세기 중엽 유럽 시계 공예의 뛰어난 기량을 보여준다."
    },
    "20": {
      "name": "아이리스",
      "description": "빈센트 반 고흐 1890년 작, 캔버스에 유채. 유명한 <아이리스>. 고흐 후기의 가장 대표적인 작품 중 하나로, 풍부한 색채와 생명력 넘치는 붓놀림으로 자연의 아름다움에 대한 깊은 경의를 표현한다."
    },
    "21": {
      "name": "뚜껑이 있는 설탕 그릇",
      "description": "Giovacchino Belli 약 1811–22년 제작 뚜껑 있는 설탕 그릇. 은 도금. Belli의 제정 양식 해석은 동시대 프랑스 해석보다 훨씬 편안하고 친근하여 신고전주의의 엄격한 선을 부드럽게 하고, 이탈리아 특유의 풍취를 지닌다."
    },
    "22": {
      "name": "주전자",
      "description": "약 1600년 제작 은 도금 에나멜 물병(ewer). 몸체에 인물과 동물의 행렬 부조가 새겨져 있으며, 이는 이집트에서 귀환하는 카이사르의 개선 또는 한니발을 꺾은 스키피오 아프리카누스의 개선을 묘사하는 르네상스 말기 금속 공예의 화려한 작품."
    },
    "23": {
      "name": "마시바 히사츠구 역의 배우 아사오 가쿠주로 1세",
      "description": "순코사이 호쿠슈(오사카) 1822년 작 목판 우키요에(니시키에). 종이에 먹과 채색, 일본 대판(오반) 종형. 오사카 가부키 배우 아사오 가쿠주로 1세가 마시바 히사츠구를 연기하는 모습; 눈을 부릅뜨고 도전하는 미에 자세가 극적 긴장감을 자아낸다."
    },
    "24": {
      "name": "안데스의 왕관",
      "description": "<안데스의 왕관> — 관 부분 약 1660년, 아치는 약 1770년. 콜롬비아 포파얀. 금 타출과 조금 기법에 에메랄드 세팅. 남미 식민지 시대의 가장 중요한 금세공품 중 하나로, 유럽과 토착 공예에 대한 신대륙 장인들의 창의적 융합을 보여준다."
    }
  },
