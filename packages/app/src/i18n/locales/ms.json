  "giftBox": {
    "1": {
      "name": "Kotak muzik",
      "description": "Loket berbentuk perisai daripada emas dan enamel. Satu sisi memaparkan adegan ladang automaton dengan kincir air; sisi lain mawar di atas latar merah. Kedua-dua sisi disempadani mutiara separuh, contoh luar biasa seni dekoratif abad ke-18."
    },
    "2": {
      "name": "FLY Kopi",
      "description": "Nikmati Fly Coffee dengan diskaun 50%. Di kafe atau dibawa pulang — cecapi aroma setiap cawan pada harga terbaik."
    },
    "3": {
      "name": "Jam berulang",
      "description": "Jam pengulang oleh Francis Perigal, pembuat jam British terkemuka (aktif 1741–67). Kes emas sebahagian berenamel; muka enamel putih dengan angka hitam dan jarum perak bertatah berlian; mekanisme bersadur emas. Kemuncak seni jam abad ke-18."
    },
    "4": {
      "name": "Gitar",
      "description": "Gitar yang belakangnya, rusuk, batang leher dan kepalanya disalut corak chevron daripada kulit kura-kura, ebony dan gading, dihias dengan gulungan bingkai, belah ketupat dan sempadan geometri. Gabungan hebat kayu dan kerja tatah yang menyerlahkan kepakaran pembuat."
    },
    "5": {
      "name": "Kotak muzik",
      "description": "Kotak muzik Switzerland sekitar 1820 berbentuk mandolin. Dihasilkan daripada pelbagai bahan dengan halus, ia menggabungkan seni kotak muzik Eropah awal abad ke-19 dengan estetika alat mandolin itu sendiri."
    },
    "6": {
      "name": "Gitar",
      "description": "Gitar berhias mewah oleh Giacomo (Jacob) Ertel, hujung abad ke-17. Spruce, ebony, kayu buah, tulang, gading, nakara dan perkamen. Karya ini menggabungkan kecintaan tukang Jerman terhadap hiasan dengan tradisi pembinaan gitar Itali."
    },
    "7": {
      "name": "Pagi Musim Sejuk di Desa",
      "description": "Litograf diwarnai tangan dari studio Currier & Ives, 1873. Pemandangan desa bersalji: giring ditarik dua ekor kuda mengangkut sepasang suami isteri dan empat bekas susu besar; jauh di belakang, ladang mereka. Contoh tipikal seni rakyat Amerika abad ke-19."
    },
    "8": {
      "name": "Beri Saya Kebebasan atau Kematian!",
      "description": "Litograf diwarnai tangan Currier & Ives, 1876, \"Beri saya kebebasan atau beri saya kematian!\". Menggambarkan Patrick Henry menyampaikan ucapan terkenalnya tentang hak-hak tanah jajahan di hadapan Perhimpunan Virginia di Richmond, Mac 1775."
    },
    "9": {
      "name": "Kotak muzik",
      "description": "Kotak muzik Switzerland berbentuk segi empat tepat daripada emas dan enamel, sekitar 1820. Sempadan berenamel biru dan kuning; penutupnya menampilkan miniatur enamel klasik yang dikelilingi mutiara separuh. Gabungan sempurna antara seni kotak muzik dan penghasilan barang kemas."
    },
    "10": {
      "name": "Kes jam",
      "description": "Kes jam oleh George Harrison, sekitar 1770. Emas sebahagian berenamel; kes luar bertatah berlian bersinar, bukti kepakaran tinggi pembuat jam dan tukang emas British pada abad ke-18."
    },
    "11": {
      "name": "Division Viol",
      "description": "Viol pembahagian oleh Richard Meares, sekitar 1680. Spruce, ebony, maple. Viol, alat bertali tertua yang paling dihormati pada akhir Renaissance, secara beransur digantikan oleh biola pada abad ke-17; saksi penting dalam sejarah muzik."
    },
    "12": {
      "name": "Naga",
      "description": "Naga gangsa awal abad ke-17 karya Giacomo Laurenziani. Ketika diperoleh telah dikatalogkan sebagai grifon; sejak dekad 1950-an James Parker mengenal pasti semula dengan betul sebagai naga; contoh barok yang menakjubkan."
    },
    "13": {
      "name": "Ros dan lili",
      "description": "Henri Fantin-Latour, 1888, minyak atas kanvas. Karya yang tersimpan dalam keadaan cemerlang ini mempamerkan pengendalian pigmen yang penuh ketangkasan: pelukis menggunakan bukan sahaja berus tetapi juga hujung pemegangnya untuk membentuk mawar dan lili dengan cahaya dan tekstur yang halus."
    },
    "14": {
      "name": "Jam",
      "description": "Jam F. L. Meybom, sekitar 1670–75. Kes emas, keluli biru, kristal batu dan perak bersadur separa dengan berlian; muka dengan enamel dilukis dan basse-taille atas emas; mekanisme tembaga bersadur emas dan keluli separa biru."
    },
    "15": {
      "name": "Kerongsang pepatung",
      "description": "Kerongsang pepatung gaya Art Nouveau oleh Edgar Bense, sekitar 1890. Emas, berlian dan enamel. Sayap halusnya dalam teknik plique-à-jour memahkotai pepatung yang dipahat halus, mengabadikan fesyen dan pembuatan barang kemas Art Nouveau serta estetika naturalis."
    },
    "16": {
      "name": "Gelang lengan",
      "description": "Gelang lengan India (bazuband), abad ke-19. Emas tenun bertatah delima dan sebiji berlian potongan rose. Contoh serupa terdapat dalam tradisi barang kemas bangsawan India, warisan estetika istana Mughal."
    },
    "17": {
      "name": "Set Perisai George Clifford",
      "description": "Set perisai yang dibuat oleh Jacob Halder pada 1586 di Armori Diraja Greenwich untuk George Clifford. Keluli, emas, kulit dan tekstil. Clifford (1558–1605) dilantik sebagai Juara Ratu pada 1590 dan dianugerahi Pangkat Garter pada tahun yang sama."
    },
    "18": {
      "name": "Kerongsang berbentuk kepala burung hantu",
      "description": "Kerongsang berbentuk kepala burung hantu oleh Castellani, sekitar 1860. Emas dan akik. Karya ini dan kumpulan yang dimiliki (lihat 2014.713.1–.10) mencerminkan minat besar Eropah abad ke-19 terhadap gaya bersejarah dan mewakili barang kemas kebangkitan arkeologi."
    },
    "19": {
      "name": "Jam",
      "description": "Jam Charles Bobinet, sekitar 1655–60. Kes akik dengan pemasangan emas berenamel; muka enamel putih dengan jarum emas; mekanisme tembaga bersadur emas dan keluli separa biru. Bukti kepakaran pembuatan jam Eropah pertengahan abad ke-17."
    },
    "20": {
      "name": "Iris",
      "description": "Vincent van Gogh, 1890, minyak atas kanvas. Lukisan Irises yang terkenal. Salah satu karya paling ikonik pada fasa akhir pelukis; dengan warna yang meriah dan sapuan berus penuh tenaga, ia memberi penghormatan mendalam kepada keindahan alam."
    },
    "21": {
      "name": "Mangkuk gula bertutup",
      "description": "Mangkuk gula bertutup oleh Giovacchino Belli, sekitar 1811–22. Perak bersadur emas. Tafsiran gaya Empire Belli lebih santai dan intim berbanding tafsiran Perancis sezaman, melembutkan garis neoklasik yang ketat dengan sentuhan Itali yang tersendiri."
    },
    "22": {
      "name": "Kendi",
      "description": "Ewer perak bersadur dan enamel, sekitar 1600. Badannya dihiasi perarakan manusia dan haiwan yang menggambarkan Kemenangan Caesar ketika pulang dari Mesir atau kemenangan Scipio Africanus selepas mengalahkan Hannibal; karya logam cemerlang akhir Renaissance."
    },
    "23": {
      "name": "Pelakon Asao Gakujūrō I sebagai Mashiba Hisatsugu",
      "description": "Ukiran kayu Shunkōsai Hokushū (Osaka), 1822. Nishiki-e atas kertas dengan dakwat dan warna, format ōban menegak Jepun. Menggambarkan pelakon kabuki Osaka Asao Gakujūrō I dalam peranan Mashiba Hisatsugu dengan pandangan garang dan pose mencabar penuh dramatik."
    },
    "24": {
      "name": "Mahkota Andes",
      "description": "\"Mahkota Andes\" — diadem sekitar 1660 dan gerbang sekitar 1770. Dari Popayán, Colombia. Emas repoussé dan ukiran bertatah zamrud. Salah satu karya emas terpenting zaman kolonial Amerika Selatan, sintesis kreatif teknik Eropah dan peribumi."
    }
  },
