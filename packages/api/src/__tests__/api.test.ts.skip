import { describe, it, expect, beforeAll, afterAll } from 'vitest'
import type { FastifyInstance } from 'fastify'
import { buildApp } from '../index'
import { STATUS_LABEL, isRevocable, type PaymentStatus } from '../paymentStateMachine'
import { getDb, closeDb } from '../db/index'
import path from 'path'
import fs from 'fs'

let app: FastifyInstance

beforeAll(async () => {
  // Close any existing singleton DB and delete the file for a clean test run
  closeDb()
  const dbDir  = process.env.DB_DIR ?? path.join(process.cwd(), 'data')
  const dbPath = path.join(dbDir, 'ipay.db')
  if (fs.existsSync(dbPath)) fs.unlinkSync(dbPath)

  app = await buildApp()
  await app.ready()
})

afterAll(async () => {
  await app.close()
})

// ── /health ────────────────────────────────────────────────────────────────
describe('GET /health', () => {
  it('returns ok', async () => {
    const res = await app.inject({ method: 'GET', url: '/health' })
    expect(res.statusCode).toBe(200)
    const body = JSON.parse(res.body)
    expect(body.status).toBe('ok')
    expect(body.version).toBe('1.0.0')
  })
})

// ── /v1/chains ─────────────────────────────────────────────────────────────
describe('GET /v1/chains', () => {
  it('returns array of chains', async () => {
    const res = await app.inject({ method: 'GET', url: '/v1/chains' })
    expect(res.statusCode).toBe(200)
    const body = JSON.parse(res.body)
    expect(Array.isArray(body)).toBe(true)
    expect(body.length).toBeGreaterThan(0)
  })
})

// ── /v1/address/resolve ────────────────────────────────────────────────────
describe('GET /v1/address/resolve', () => {
  it('resolves a bech32 init address', async () => {
    const res = await app.inject({
      method: 'GET',
      url: '/v1/address/resolve?address=init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
    })
    expect(res.statusCode).toBe(200)
    const body = JSON.parse(res.body)
    expect(body.original).toBe('init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d')
    expect(body.resolved).toBeDefined()
  })

  it('returns 400 when address missing', async () => {
    const res = await app.inject({ method: 'GET', url: '/v1/address/resolve' })
    expect(res.statusCode).toBe(400)
  })

  it('returns 400 for invalid address', async () => {
    const res = await app.inject({
      method: 'GET',
      url: '/v1/address/resolve?address=not-valid',
    })
    expect(res.statusCode).toBe(400)
    const body = JSON.parse(res.body)
    expect(body.error).toBe('INVALID_ADDRESS')
  })
})

// 测试专用请求头（绕过 sanctions 中间件的 ToS 检查）
const TOS_HEADERS = {
  'X-IPay-ToS-Accepted': '1',
  'X-Wallet-Address': 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
  'Content-Type': 'application/json',
}

// ── /v1/payments ───────────────────────────────────────────────────────────
describe('POST /v1/payments', () => {
  it('creates a payment request', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'interwoven-1',
        amount: '100.00',
        reference: 'order-001',
      },
    })
    expect(res.statusCode).toBe(201)
    const body = JSON.parse(res.body)
    expect(body.paymentId).toMatch(/^iPay-/)
    expect(body.version).toBe('1')
    expect(body.amount).toBe('100.000000')
    expect(body.token).toBe('iUSD')
    expect(body.status).toBe('created')
    expect(body.paymentUrl).toContain('iusd-pay.xyz/pay/')
  })

  it('returns 400 for unsupported chain', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'evm-bad',
        amount: '10.00',
      },
    })
    expect(res.statusCode).toBe(400)
    const body = JSON.parse(res.body)
    expect(body.error).toBe('UNSUPPORTED_CHAIN')
  })

  it('returns 400 for missing recipient', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: { chain: 'interwoven-1', amount: '10.00' },
    })
    expect(res.statusCode).toBe(400)
  })

  it('returns 400 for invalid amount', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'interwoven-1',
        amount: '-5',
      },
    })
    expect(res.statusCode).toBe(400)
  })
})

describe('GET /v1/payments/:id', () => {
  it('retrieves created payment', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'interwoven-1',
        amount: '50.00',
      },
    })
    const { paymentId } = JSON.parse(create.body)

    const get = await app.inject({ method: 'GET', url: `/v1/payments/${paymentId}/status` })
    expect(get.statusCode).toBe(200)
    const body = JSON.parse(get.body)
    expect(body.paymentId).toBe(paymentId)
    expect(body.status).toBe('created')
  })

  it('returns 404 for unknown id', async () => {
    const res = await app.inject({ method: 'GET', url: '/v1/payments/does-not-exist/status' })
    expect(res.statusCode).toBe(404)
    expect(JSON.parse(res.body).error).toBe('NOT_FOUND')
  })
})

