// ── /v1/travel-rule ─────────────────────────────────────────────────────────
describe('POST /v1/travel-rule/check', () => {
  it('returns requires=true for $1000+', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/travel-rule/check',
      payload: { amount_usd: 1500 },
    })
    expect(res.statusCode).toBe(200)
    const body = JSON.parse(res.body)
    expect(body.requires_travel_rule).toBe(true)
    expect(body.threshold_usd).toBe(1000)
  })

  it('returns requires=false for under threshold', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/travel-rule/check',
      payload: { amount_usd: 500 },
    })
    expect(JSON.parse(res.body).requires_travel_rule).toBe(false)
  })
})

describe('POST /v1/travel-rule/packets', () => {
  it('generates IVMS101 packet for $1000+ transaction', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/travel-rule/packets',
      payload: {
        order_id:            'iPay-tr-test001',
        amount_usd:          2500,
        chain:               'interwoven-1',
        originator_address:  'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        beneficiary_address: 'init1aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa',
      },
    })
    expect(res.statusCode).toBe(201)
    const body = JSON.parse(res.body)
    expect(body.standard).toBe('IVMS101')
    expect(body.packet.version).toBe('1.0')
    expect(body.packet.transaction.order_id).toBe('iPay-tr-test001')
  })

  it('rejects packet for sub-threshold amount', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/travel-rule/packets',
      payload: {
        order_id: 'iPay-small',
        amount_usd: 50,
        chain: 'interwoven-1',
        originator_address:  'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        beneficiary_address: 'init1aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa',
      },
    })
    expect(res.statusCode).toBe(400)
    expect(JSON.parse(res.body).error).toBe('TRAVEL_RULE_NOT_REQUIRED')
  })
})

// ── /v1/history ───────────────────────────────────────────────────────────────
describe('History routes', () => {
  const VK_HASH = 'abc123def456abc123def456abc123de'

  it('stores an encrypted note', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/history/notes',
      payload: {
        order_id:        'iPay-hist-test001',
        owner_vk_hash:   VK_HASH,
        ciphertext:      'base64encodedciphertext==',
        instrument_type: 0,
        chain:           'interwoven-1',
      },
    })
    expect(res.statusCode).toBe(201)
    const body = JSON.parse(res.body)
    expect(body.note_id).toBe('NOTE-iPay-hist-test001')
    expect(body.deletable_at).toBeGreaterThan(Math.floor(Date.now()/1000))
  })

  it('lists notes by vk_hash', async () => {
    const res = await app.inject({
      method: 'GET',
      url: `/v1/history?vk_hash=${VK_HASH}`,
    })
    expect(res.statusCode).toBe(200)
    const body = JSON.parse(res.body)
    expect(Array.isArray(body.notes)).toBe(true)
    expect(body.notes.length).toBeGreaterThan(0)
    expect(body.notes[0].ciphertext).toBeDefined()
  })

  it('archives and unarchives a note', async () => {
    const archive = await app.inject({
      method: 'POST',
      url: '/v1/history/iPay-hist-test001/archive',
      payload: { vk_hash: VK_HASH },
    })
    expect(archive.statusCode).toBe(200)
    expect(JSON.parse(archive.body).archived).toBe(true)

    const unarchive = await app.inject({
      method: 'POST',
      url: '/v1/history/iPay-hist-test001/unarchive',
      payload: { vk_hash: VK_HASH },
    })
    expect(JSON.parse(unarchive.body).archived).toBe(false)
  })

  it('blocks deletion during retention period', async () => {
    const res = await app.inject({
      method: 'DELETE',
      url: '/v1/history/iPay-hist-test001',
      payload: { vk_hash: VK_HASH },
    })
    expect(res.statusCode).toBe(403)
    expect(JSON.parse(res.body).error).toBe('RETENTION_PERIOD_ACTIVE')
  })

  it('returns 401 without vk_hash', async () => {
    const res = await app.inject({ method: 'GET', url: '/v1/history' })
    expect(res.statusCode).toBe(401)
  })
})

// ── /v1/subscriptions ─────────────────────────────────────────────────────────
describe('Subscription routes', () => {
  const PAYER    = 'init1payeraaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1b2c'
  const MERCHANT = 'init1merchantbbbbbbbbbbbbbbbbbbbbbbbbbbb1b2c'

  it('creates a subscription', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/subscriptions',
      payload: {
        payer_address:    PAYER,
        merchant_address: MERCHANT,
        amount:           '9.99',
        interval:         'monthly',
        chain:            'interwoven-1',
      },
    })
    expect(res.statusCode).toBe(201)
    const body = JSON.parse(res.body)
    expect(body.sub_id).toMatch(/^SUB-/)
    expect(body.status).toBe('active')
    expect(body.interval).toBe('monthly')
  })

  it('returns 400 for invalid interval', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/subscriptions',
      payload: {
        payer_address: PAYER, merchant_address: MERCHANT,
        amount: '10', interval: 'daily',
      },
    })
    expect(res.statusCode).toBe(400)
    expect(JSON.parse(res.body).error).toBe('INVALID_INTERVAL')
  })

  it('can pause and resume a subscription', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/subscriptions',
      payload: { payer_address: PAYER, merchant_address: MERCHANT, amount: '5', interval: 'monthly' },
    })
    const { sub_id } = JSON.parse(create.body)

    const pause = await app.inject({
      method: 'POST', url: `/v1/subscriptions/${sub_id}/pause`,
      payload: { payer_address: PAYER },
    })
    expect(JSON.parse(pause.body).status).toBe('paused')

    const resume = await app.inject({
      method: 'POST', url: `/v1/subscriptions/${sub_id}/resume`,
      payload: { payer_address: PAYER },
    })
    expect(JSON.parse(resume.body).status).toBe('active')
  })

  it('can cancel a subscription', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/subscriptions',
      payload: { payer_address: PAYER, merchant_address: MERCHANT, amount: '20', interval: 'yearly' },
    })
    const { sub_id } = JSON.parse(create.body)

    const cancel = await app.inject({
      method: 'POST', url: `/v1/subscriptions/${sub_id}/cancel`,
      payload: { payer_address: PAYER },
    })
    expect(JSON.parse(cancel.body).status).toBe('cancelled')
  })
})

