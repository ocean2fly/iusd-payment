// ── 2a. Status flow — GET reflects live DB status ────────────────────────────
describe('GET /v1/payments/:id — reflects live DB status', () => {
  it('returns processing after manual DB update', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'interwoven-1',
        amount: '25.00',
      },
    })
    expect(create.statusCode).toBe(201)
    const { paymentId } = JSON.parse(create.body)

    // Manually update DB to simulate state machine transition
    getDb().prepare("UPDATE payments SET status = 'processing' WHERE payment_id = ?").run(paymentId)

    const get = await app.inject({ method: 'GET', url: `/v1/payments/${paymentId}/status` })
    expect(get.statusCode).toBe(200)
    expect(JSON.parse(get.body).status).toBe('processing')
  })

  it('returns pending_claim after manual DB update', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'interwoven-1',
        amount: '30.00',
      },
    })
    const { paymentId } = JSON.parse(create.body)

    getDb().prepare("UPDATE payments SET status = 'pending_claim' WHERE payment_id = ?").run(paymentId)

    const get = await app.inject({ method: 'GET', url: `/v1/payments/${paymentId}/status` })
    expect(get.statusCode).toBe(200)
    expect(JSON.parse(get.body).status).toBe('pending_claim')
  })

  it('returns requires_action after manual DB update', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'interwoven-1',
        amount: '15.00',
      },
    })
    const { paymentId } = JSON.parse(create.body)

    getDb().prepare("UPDATE payments SET status = 'requires_action' WHERE payment_id = ?").run(paymentId)

    const get = await app.inject({ method: 'GET', url: `/v1/payments/${paymentId}/status` })
    expect(get.statusCode).toBe(200)
    expect(JSON.parse(get.body).status).toBe('requires_action')
  })
})

// ── 2b. Event log — table exists and can be queried ──────────────────────────
describe('event_log table — exists and is writable', () => {
  it('event_log table exists in the DB', () => {
    const db = getDb()
    const tables = db.prepare(
      "SELECT name FROM sqlite_master WHERE type='table' AND name='event_log'"
    ).all() as { name: string }[]
    expect(tables.length).toBe(1)
    expect(tables[0].name).toBe('event_log')
  })

  it('can insert and query event_log rows', () => {
    const db = getDb()
    const now = new Date().toISOString()
    db.prepare(`
      INSERT INTO event_log (entity_type, entity_id, from_status, to_status, actor, created_at)
      VALUES ('payment', 'iPay-evt-api-test', 'created', 'processing', 'test-actor', ?)
    `).run(now)

    const rows = db.prepare(
      "SELECT * FROM event_log WHERE entity_id = 'iPay-evt-api-test'"
    ).all() as any[]
    expect(rows.length).toBeGreaterThan(0)
    expect(rows[0].from_status).toBe('created')
    expect(rows[0].to_status).toBe('processing')
    expect(rows[0].actor).toBe('test-actor')
  })

  it('event_log accumulates entries for a real payment transitions', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: {
        recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        chain: 'interwoven-1',
        amount: '42.00',
      },
    })
    const { paymentId } = JSON.parse(create.body)

    // Manually log a transition to verify event_log works for real payment IDs
    const db = getDb()
    const now = new Date().toISOString()
    db.prepare(`
      INSERT INTO event_log (entity_type, entity_id, from_status, to_status, actor, created_at)
      VALUES ('payment', ?, 'created', 'processing', 'relayer', ?)
    `).run(paymentId, now)

    const logs = db.prepare('SELECT * FROM event_log WHERE entity_id = ?').all(paymentId) as any[]
    expect(logs.length).toBeGreaterThanOrEqual(1)
    expect(logs.some((l: any) => l.to_status === 'processing')).toBe(true)
  })
})

// ── 2c. POST /v1/payments — idempotency ──────────────────────────────────────
describe('POST /v1/payments — idempotency_key behaviour', () => {
  it('second call with same idempotency_key returns 200 with same paymentId', async () => {
    const payload = {
      recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
      chain: 'interwoven-1',
      amount: '77.00',
      idempotency_key: `idem-${Date.now()}-unique`,
    }

    const first = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload,
    })
    expect(first.statusCode).toBe(201)
    const firstBody = JSON.parse(first.body)

    const second = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload,
    })
    // Implementation returns 200 with same payment on duplicate idempotency_key
    expect(second.statusCode).toBe(200)
    const secondBody = JSON.parse(second.body)
    expect(secondBody.paymentId).toBe(firstBody.paymentId)
  })

  it('different idempotency_keys create different payments', async () => {
    const base = {
      recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
      chain: 'interwoven-1',
      amount: '5.00',
    }

    const ts = Date.now()
    const first = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: { ...base, idempotency_key: `idem-diff-${ts}-A` },
    })
    const second = await app.inject({
      method: 'POST',
      url: '/v1/payments',
      headers: TOS_HEADERS,
      payload: { ...base, idempotency_key: `idem-diff-${ts}-B` },
    })
    expect(first.statusCode).toBe(201)
    expect(second.statusCode).toBe(201)
    expect(JSON.parse(first.body).paymentId).not.toBe(JSON.parse(second.body).paymentId)
  })

  it('no idempotency_key allows duplicate requests (creates new payment each time)', async () => {
    const payload = {
      recipient: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
      chain: 'interwoven-1',
      amount: '8.00',
    }

    const first = await app.inject({ method: 'POST', url: '/v1/payments', headers: TOS_HEADERS, payload })
    const second = await app.inject({ method: 'POST', url: '/v1/payments', headers: TOS_HEADERS, payload })
    expect(first.statusCode).toBe(201)
    expect(second.statusCode).toBe(201)
    expect(JSON.parse(first.body).paymentId).not.toBe(JSON.parse(second.body).paymentId)
  })
})

// ── 2d. STATUS_LABEL completeness ────────────────────────────────────────────
describe('STATUS_LABEL — all 10 statuses have non-empty Chinese labels', () => {
  const allStatuses: PaymentStatus[] = [
    'created', 'processing', 'pending_claim', 'requires_action',
    'confirmed', 'reject_pending', 'revoked', 'refunded', 'expired', 'failed',
  ]

  it('STATUS_LABEL has exactly 10 entries', () => {
    expect(Object.keys(STATUS_LABEL).length).toBe(10)
  })

  allStatuses.forEach((status) => {
    it(`STATUS_LABEL['${status}'] is a non-empty string`, () => {
      const label = STATUS_LABEL[status]
      expect(typeof label).toBe('string')
      expect(label.length).toBeGreaterThan(0)
    })
  })

  it('STATUS_LABEL values are distinct (no two states share the same label)', () => {
    const labels = Object.values(STATUS_LABEL)
    const uniqueLabels = new Set(labels)
    expect(uniqueLabels.size).toBe(labels.length)
  })
})

// ── 2e. REVOCABLE_STATES — both pending_claim and requires_action ─────────────
describe('isRevocable() — covers critical states', () => {
  it('pending_claim is revocable', () => {
    expect(isRevocable('pending_claim')).toBe(true)
  })

  it('requires_action is revocable (critical — historical bug fix)', () => {
    expect(isRevocable('requires_action')).toBe(true)
  })

  it('created is NOT revocable', () => {
    expect(isRevocable('created')).toBe(false)
  })

  it('processing is NOT revocable', () => {
    expect(isRevocable('processing')).toBe(false)
  })

  it('confirmed is NOT revocable (terminal)', () => {
    expect(isRevocable('confirmed')).toBe(false)
  })

  it('reject_pending is NOT revocable', () => {
    expect(isRevocable('reject_pending')).toBe(false)
  })

  it('revoked is NOT revocable (terminal)', () => {
    expect(isRevocable('revoked')).toBe(false)
  })

  it('refunded is NOT revocable (terminal)', () => {
    expect(isRevocable('refunded')).toBe(false)
  })

  it('expired is NOT revocable (terminal)', () => {
    expect(isRevocable('expired')).toBe(false)
  })

  it('failed is NOT revocable (terminal)', () => {
    expect(isRevocable('failed')).toBe(false)
  })
})
