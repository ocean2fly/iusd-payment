describe('POST /v1/invoices/:id/pay', () => {
  it('confirms invoice payment', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/invoices',
      headers: TOS_HEADERS,
      payload: {
        merchant_address: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        amount: '100.00',
        description: 'Pay test',
        chain: 'interwoven-1',
      },
    })
    const { invoice_id } = JSON.parse(create.body)

    const pay = await app.inject({
      method: 'POST',
      url: `/v1/invoices/${invoice_id}/pay`,
      payload: {
        nullifier: 'abc123def456',
        proof: { pi_a: 'a', pi_b: 'b', pi_c: 'c' },
      },
    })
    expect(pay.statusCode).toBe(200)
    const body = JSON.parse(pay.body)
    expect(body.status).toBe('paid')
    expect(body.nullifier).toBe('abc123def456')
  })
})

// ── /v1/gifts (Chocolate Box) ─────────────────────────────────────────────────
describe('POST /v1/gifts', () => {
  it('creates a gift box (equal mode)', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/gifts',
      payload: {
        creator_address: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        total_amount: '100.00',
        slot_count: 10,
        mode: 'equal',
        access: 'open',
        message: 'Happy holidays!',
      },
    })
    expect(res.statusCode).toBe(201)
    const body = JSON.parse(res.body)
    expect(body.box_id).toMatch(/^GP-/)
    expect(body.slot_count).toBe(10)
    expect(body.mode).toBe('equal')
    expect(body.claim_url).toContain('/gift/GP-')
  })

  it('returns 400 for empty whitelist when access=whitelist', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/gifts',
      payload: {
        creator_address: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        total_amount: '50.00',
        slot_count: 5,
        access: 'whitelist',
        whitelist: [],
      },
    })
    expect(res.statusCode).toBe(400)
    expect(JSON.parse(res.body).error).toBe('WHITELIST_EMPTY')
  })
})

describe('POST /v1/gifts/:id/claim', () => {
  it('allows valid ZK claim', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/gifts',
      payload: {
        creator_address: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        total_amount: '50.00',
        slot_count: 5,
        mode: 'equal',
        access: 'open',
      },
    })
    const { box_id } = JSON.parse(create.body)

    const claim = await app.inject({
      method: 'POST',
      url: `/v1/gifts/${box_id}/claim`,
      payload: {
        claimer_address: 'init1abc123def456abc123def456abc123def456a1b2c3',
        nullifier: 'unique-nullifier-abc123',
        proof: { pi_a: 'a', pi_b: 'b', pi_c: 'c' },
      },
    })
    expect(claim.statusCode).toBe(200)
    const body = JSON.parse(claim.body)
    expect(body.claim_id).toMatch(/^CLM-/)
    expect(body.amount).toBe('10.000000')
  })

  it('prevents double-claim with same nullifier', async () => {
    const create = await app.inject({
      method: 'POST',
      url: '/v1/gifts',
      payload: {
        creator_address: 'init1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqpqr5e3d',
        total_amount: '20.00',
        slot_count: 4,
        mode: 'equal',
        access: 'open',
      },
    })
    const { box_id } = JSON.parse(create.body)

    const payload = {
      claimer_address: 'init1dup000aaaaaaaaaaaaaaaaaaaaaaaaaaa1b2c3',
      nullifier: 'dup-nullifier-xyz',
      proof: { pi_a: 'a', pi_b: 'b', pi_c: 'c' },
    }
    await app.inject({ method: 'POST', url: `/v1/gifts/${box_id}/claim`, payload })
    const second = await app.inject({ method: 'POST', url: `/v1/gifts/${box_id}/claim`, payload })
    expect(second.statusCode).toBe(409)
  })
})

// ── /v1/merchants ─────────────────────────────────────────────────────────────
describe('POST /v1/merchants/register', () => {
  it('registers a merchant', async () => {
    const res = await app.inject({
      method: 'POST',
      url: '/v1/merchants/register',
      payload: {
        wallet_address: 'init1merchanttestaaaaaaaaaaaaaaaaaaaaaaaaa1b2',
        display_name: 'Test Merchant Co.',
        email: 'merchant@test.com',
        website: 'https://testmerchant.com',
      },
    })
    expect(res.statusCode).toBe(201)
    const body = JSON.parse(res.body)
    expect(body.merchant_id).toMatch(/^MER-/)
    expect(body.display_name).toBe('Test Merchant Co.')
    expect(body.profile_url).toContain('/merchant/MER-')
  })

  it('returns 409 for duplicate wallet', async () => {
    const payload = {
      wallet_address: 'init1dupmerchantaaaaaaaaaaaaaaaaaaaaaaaa1b2c',
      display_name: 'Dup Merchant',
    }
    await app.inject({ method: 'POST', url: '/v1/merchants/register', payload })
    const second = await app.inject({ method: 'POST', url: '/v1/merchants/register', payload })
    expect(second.statusCode).toBe(409)
  })
})

describe('GET /v1/merchants/:addr', () => {
