    'sender',
    'chain',
    'amount',
    'amount_micro',
    'privacy_level',
    'processing_tx_hash',
    'tx_hash',
    'claim_tx_hash',
    'reject_tx_hash',
    'refund_tx_hash',
    'idempotency_key',
    'created_at',
    'expires_at',
    'updated_at',
  ]

  requiredCols.forEach((col) => {
    it(`has column: ${col}`, () => {
      expect(getColumnNames(db, 'payments')).toContain(col)
    })
  })
})

