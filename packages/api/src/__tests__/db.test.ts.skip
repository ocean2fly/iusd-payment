/**
 * DB schema tests — verifies tables, columns, constraints, and defaults
 * using an isolated in-memory SQLite database.
 */

import { describe, it, expect, beforeEach, afterEach } from 'vitest'
import Database from 'better-sqlite3'
import { createTestDb } from '../db/index'

let db: Database.Database

// ---------------------------------------------------------------------------
// Helpers
// ---------------------------------------------------------------------------

function getTableNames(d: Database.Database): string[] {
  const rows = d.prepare(
    "SELECT name FROM sqlite_master WHERE type='table' ORDER BY name"
  ).all() as { name: string }[]
  return rows.map((r) => r.name)
}

function getColumnNames(d: Database.Database, table: string): string[] {
  const rows = d.prepare(`PRAGMA table_info(${table})`).all() as { name: string }[]
  return rows.map((r) => r.name)
}

function insertPayment(
  d: Database.Database,
  paymentId: string,
  opts: { idempotencyKey?: string | null; recipient?: string } = {}
) {
  const now = new Date().toISOString()
  d.prepare(`
    INSERT INTO payments
      (payment_id, recipient, chain, amount, status, idempotency_key, created_at, expires_at, updated_at)
    VALUES (?, ?, 'interwoven-1', '10.000000', 'created', ?, ?, ?, ?)
  `).run(
    paymentId,
    opts.recipient ?? 'init1testaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa1b2c',
    opts.idempotencyKey ?? null,
    now,
    now,
    now,
  )
}

// ---------------------------------------------------------------------------
// Setup
// ---------------------------------------------------------------------------

beforeEach(() => {
  db = createTestDb()
})

afterEach(() => {
  db.close()
})

// ===========================================================================
// Table existence
// ===========================================================================
describe('DB schema — required tables exist', () => {
  const requiredTables = [
    'payments',
    'relay_secrets',
    'inbox_claims',
    'viewing_keys',
    'refunds',
    'event_log',
    'support_tickets',
    'audit_packages',
    'tos_records',
    'merchant_profiles',
  ]

  it('creates all 10 required tables', () => {
    const tables = getTableNames(db)
    for (const t of requiredTables) {
      expect(tables, `missing table: ${t}`).toContain(t)
    }
  })

  requiredTables.forEach((table) => {
    it(`table "${table}" exists`, () => {
      expect(getTableNames(db)).toContain(table)
    })
  })
})

