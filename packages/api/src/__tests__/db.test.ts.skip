// ===========================================================================
// Default values
// ===========================================================================
describe('payments table — default values', () => {
  it('status defaults to "created"', () => {
    const now = new Date().toISOString()
    db.prepare(`
      INSERT INTO payments (payment_id, recipient, chain, amount, created_at, expires_at)
      VALUES (?, 'init1test', 'interwoven-1', '5.000000', ?, ?)
    `).run('iPay-default-test', now, now)

    const row = db.prepare('SELECT status FROM payments WHERE payment_id = ?').get('iPay-default-test') as any
    expect(row.status).toBe('created')
  })

  it('updated_at is set automatically on insert', () => {
    const now = new Date().toISOString()
    db.prepare(`
      INSERT INTO payments (payment_id, recipient, chain, amount, created_at, expires_at)
      VALUES (?, 'init1test', 'interwoven-1', '5.000000', ?, ?)
    `).run('iPay-updat-test', now, now)

    const row = db.prepare('SELECT updated_at FROM payments WHERE payment_id = ?').get('iPay-updat-test') as any
    expect(row.updated_at).toBeTruthy()
  })
})

describe('refunds table — default status', () => {
  it('status defaults to "pending"', () => {
    // Insert a parent payment first (FK constraint)
    insertPayment(db, 'iPay-parent-refund-001')

    const now = new Date().toISOString()
    db.prepare(`
      INSERT INTO refunds (refund_id, payment_id, amount, reason, created_at, updated_at)
      VALUES ('REF-001', 'iPay-parent-refund-001', '10.000000', 'test', ?, ?)
    `).run(now, now)

    const row = db.prepare('SELECT status FROM refunds WHERE refund_id = ?').get('REF-001') as any
    expect(row.status).toBe('pending')
  })
})

describe('event_log table — default entity_type', () => {
  it('entity_type defaults to "payment"', () => {
    const now = new Date().toISOString()
    db.prepare(`
      INSERT INTO event_log (entity_id, to_status, actor, created_at)
      VALUES ('iPay-evt-test', 'processing', 'system', ?)
    `).run(now)

    const row = db.prepare('SELECT entity_type FROM event_log WHERE entity_id = ?').get('iPay-evt-test') as any
    expect(row.entity_type).toBe('payment')
  })
})

// ===========================================================================
// Constraints
// ===========================================================================
describe('payments table — constraints', () => {
  it('idempotency_key has UNIQUE constraint (duplicate insert throws)', () => {
    insertPayment(db, 'iPay-idem-001', { idempotencyKey: 'key-abc-123' })

    expect(() => {
      insertPayment(db, 'iPay-idem-002', { idempotencyKey: 'key-abc-123' })
    }).toThrow()
  })

  it('allows two payments with NULL idempotency_key (NULL is not unique)', () => {
    insertPayment(db, 'iPay-null-001', { idempotencyKey: null })
    expect(() => {
      insertPayment(db, 'iPay-null-002', { idempotencyKey: null })
    }).not.toThrow()
  })

  it('payment_id is PRIMARY KEY (duplicate throws)', () => {
    insertPayment(db, 'iPay-pk-001')
    expect(() => {
      insertPayment(db, 'iPay-pk-001')
    }).toThrow()
  })

  it('recipient is NOT NULL (missing recipient throws)', () => {
    const now = new Date().toISOString()
    expect(() => {
      db.prepare(`
        INSERT INTO payments (payment_id, chain, amount, created_at, expires_at)
        VALUES ('iPay-norecip', 'interwoven-1', '5.0', ?, ?)
      `).run(now, now)
    }).toThrow()
  })
})

describe('refunds table — foreign key constraint', () => {
  it('inserting refund with non-existent payment_id throws (FK)', () => {
    const now = new Date().toISOString()
    expect(() => {
      db.prepare(`
        INSERT INTO refunds (refund_id, payment_id, amount, reason, created_at, updated_at)
        VALUES ('REF-FK-BAD', 'iPay-does-not-exist', '5.0', 'test', ?, ?)
      `).run(now, now)
    }).toThrow()
  })
})

// ===========================================================================
// event_log — can insert and query
// ===========================================================================
describe('event_log — CRUD operations', () => {
  it('can insert and query event_log rows', () => {
    const now = new Date().toISOString()
    db.prepare(`
      INSERT INTO event_log (entity_type, entity_id, from_status, to_status, actor, tx_hash, note, created_at)
      VALUES ('payment', 'iPay-evt-001', 'created', 'processing', 'relayer', '0xtxhash', 'test note', ?)
    `).run(now)

    const row = db.prepare('SELECT * FROM event_log WHERE entity_id = ?').get('iPay-evt-001') as any
    expect(row).toBeDefined()
    expect(row.from_status).toBe('created')
    expect(row.to_status).toBe('processing')
    expect(row.actor).toBe('relayer')
    expect(row.tx_hash).toBe('0xtxhash')
    expect(row.note).toBe('test note')
  })

  it('id column is autoincrement', () => {
    const now = new Date().toISOString()
    db.prepare(`INSERT INTO event_log (entity_id, to_status, actor, created_at) VALUES ('p1', 'processing', 'sys', ?)`).run(now)
    db.prepare(`INSERT INTO event_log (entity_id, to_status, actor, created_at) VALUES ('p2', 'confirmed', 'sys', ?)`).run(now)

    const rows = db.prepare('SELECT id FROM event_log ORDER BY id').all() as { id: number }[]
    expect(rows.length).toBe(2)
    expect(rows[1].id).toBeGreaterThan(rows[0].id)
  })
})

