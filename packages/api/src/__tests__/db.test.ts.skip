// support_tickets table
// ===========================================================================
describe('support_tickets table — schema', () => {
  it('has expected columns', () => {
    const cols = getColumnNames(db, 'support_tickets')
    expect(cols).toContain('ticket_id')
    expect(cols).toContain('payment_id')
    expect(cols).toContain('description')
    expect(cols).toContain('status')
  })
})

// ===========================================================================
// DB isolation — each test gets its own DB
// ===========================================================================
describe('DB isolation between tests', () => {
  it('first test inserts a row', () => {
    insertPayment(db, 'iPay-iso-001')
    const row = db.prepare('SELECT * FROM payments WHERE payment_id = ?').get('iPay-iso-001')
    expect(row).toBeDefined()
  })

  it('second test does not see rows from first test (isolated DB)', () => {
    // 'iPay-iso-001' should NOT exist here since each test gets a fresh DB
    const row = db.prepare('SELECT * FROM payments WHERE payment_id = ?').get('iPay-iso-001')
    expect(row).toBeUndefined()
  })
})
